{% doc %}
  @prompt
    A section to display our upcoming games with a tab that leads to the games tab. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-upcoming-games-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-upcoming-games-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-upcoming-games-header-{{ ai_gen_id }} {
    margin-bottom: 30px;
  }

  .ai-upcoming-games-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 10px 0;
    font-weight: 700;
  }

  .ai-upcoming-games-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
  }

  .ai-upcoming-games-tabs-{{ ai_gen_id }} {
    display: flex;
    gap: 10px;
    margin-bottom: 30px;
    border-bottom: 2px solid {{ block.settings.tab_border_color }};
    flex-wrap: wrap;
  }

  .ai-upcoming-games-tab-{{ ai_gen_id }} {
    padding: 12px 24px;
    background: none;
    border: none;
    border-bottom: 3px solid transparent;
    cursor: pointer;
    font-size: {{ block.settings.tab_font_size }}px;
    color: {{ block.settings.tab_text_color }};
    transition: all 0.3s ease;
    margin-bottom: -2px;
    font-weight: 500;
  }

  .ai-upcoming-games-tab-{{ ai_gen_id }}:hover {
    color: {{ block.settings.tab_active_color }};
  }

  .ai-upcoming-games-tab-{{ ai_gen_id }}.active {
    color: {{ block.settings.tab_active_color }};
    border-bottom-color: {{ block.settings.tab_active_color }};
  }

  .ai-upcoming-games-content-{{ ai_gen_id }} {
    display: none;
  }

  .ai-upcoming-games-content-{{ ai_gen_id }}.active {
    display: block;
  }

  .ai-upcoming-games-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
  }

  .ai-upcoming-game-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-upcoming-game-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
  }

  .ai-upcoming-game-image-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    position: relative;
  }

  .ai-upcoming-game-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-upcoming-game-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-upcoming-game-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-upcoming-game-info-{{ ai_gen_id }} {
    padding: 20px;
  }

  .ai-upcoming-game-name-{{ ai_gen_id }} {
    font-size: {{ block.settings.game_title_size }}px;
    color: {{ block.settings.game_title_color }};
    margin: 0 0 8px 0;
    font-weight: 600;
  }

  .ai-upcoming-game-date-{{ ai_gen_id }} {
    font-size: {{ block.settings.game_date_size }}px;
    color: {{ block.settings.game_date_color }};
    margin: 0 0 12px 0;
  }

  .ai-upcoming-game-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.game_description_size }}px;
    color: {{ block.settings.game_description_color }};
    line-height: 1.5;
    margin: 0;
  }

  .ai-upcoming-games-empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #999;
    font-size: 16px;
  }

  @media screen and (max-width: 749px) {
    .ai-upcoming-games-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-upcoming-games-tabs-{{ ai_gen_id }} {
      overflow-x: auto;
      flex-wrap: nowrap;
    }

    .ai-upcoming-games-tab-{{ ai_gen_id }} {
      white-space: nowrap;
    }
  }
{% endstyle %}

<upcoming-games-{{ ai_gen_id }} class="ai-upcoming-games-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-upcoming-games-container-{{ ai_gen_id }}">
    {% if block.settings.title != blank or block.settings.subtitle != blank %}
      <div class="ai-upcoming-games-header-{{ ai_gen_id }}">
        {% if block.settings.title != blank %}
          <h2 class="ai-upcoming-games-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
        {% endif %}
        {% if block.settings.subtitle != blank %}
          <p class="ai-upcoming-games-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-upcoming-games-tabs-{{ ai_gen_id }}" role="tablist">
      <button
        class="ai-upcoming-games-tab-{{ ai_gen_id }} active"
        role="tab"
        aria-selected="true"
        aria-controls="ai-upcoming-games-panel-upcoming-{{ ai_gen_id }}"
        data-tab="upcoming"
      >
        {{ block.settings.upcoming_tab_label }}
      </button>
      <button
        class="ai-upcoming-games-tab-{{ ai_gen_id }}"
        role="tab"
        aria-selected="false"
        aria-controls="ai-upcoming-games-panel-all-{{ ai_gen_id }}"
        data-tab="all"
      >
        {{ block.settings.all_games_tab_label }}
      </button>
    </div>

    <div
      id="ai-upcoming-games-panel-upcoming-{{ ai_gen_id }}"
      class="ai-upcoming-games-content-{{ ai_gen_id }} active"
      role="tabpanel"
    >
      {% assign has_upcoming_games = false %}
      <div class="ai-upcoming-games-grid-{{ ai_gen_id }}">
        {% for i in (1..6) %}
          {% liquid
            assign game_enabled_key = 'game_' | append: i | append: '_enabled'
            assign game_name_key = 'game_' | append: i | append: '_name'
            assign game_date_key = 'game_' | append: i | append: '_date'
            assign game_description_key = 'game_' | append: i | append: '_description'
            assign game_image_key = 'game_' | append: i | append: '_image'

            assign game_enabled = block.settings[game_enabled_key]
            assign game_name = block.settings[game_name_key]
            assign game_date = block.settings[game_date_key]
            assign game_description = block.settings[game_description_key]
            assign game_image = block.settings[game_image_key]
          %}

          {% if game_enabled %}
            {% assign has_upcoming_games = true %}
            <div class="ai-upcoming-game-card-{{ ai_gen_id }}">
              <div class="ai-upcoming-game-image-{{ ai_gen_id }}">
                {% if game_image %}
                  <img
                    src="{{ game_image | image_url: width: 600 }}"
                    alt="{{ game_name | escape }}"
                    loading="lazy"
                    width="600"
                    height="338"
                  >
                {% else %}
                  <div class="ai-upcoming-game-image-placeholder-{{ ai_gen_id }}">
                    {{ 'image' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>
              <div class="ai-upcoming-game-info-{{ ai_gen_id }}">
                {% if game_name != blank %}
                  <h3 class="ai-upcoming-game-name-{{ ai_gen_id }}">{{ game_name }}</h3>
                {% endif %}
                {% if game_date != blank %}
                  <p class="ai-upcoming-game-date-{{ ai_gen_id }}">{{ game_date }}</p>
                {% endif %}
                {% if game_description != blank %}
                  <div class="ai-upcoming-game-description-{{ ai_gen_id }}">{{ game_description }}</div>
                {% endif %}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
      {% unless has_upcoming_games %}
        <div class="ai-upcoming-games-empty-{{ ai_gen_id }}">
          No upcoming games scheduled. Check back soon!
        </div>
      {% endunless %}
    </div>

    <div
      id="ai-upcoming-games-panel-all-{{ ai_gen_id }}"
      class="ai-upcoming-games-content-{{ ai_gen_id }}"
      role="tabpanel"
    >
      {% if block.settings.all_games_page != blank %}
        <div class="ai-upcoming-games-grid-{{ ai_gen_id }}">
          {{ block.settings.all_games_page.content }}
        </div>
      {% else %}
        <div class="ai-upcoming-games-empty-{{ ai_gen_id }}">
          Select a page to display all games content.
        </div>
      {% endif %}
    </div>
  </div>
</upcoming-games-{{ ai_gen_id }}>

<script>
  (function() {
    class UpcomingGames{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.tabs = this.querySelectorAll('.ai-upcoming-games-tab-{{ ai_gen_id }}');
        this.panels = this.querySelectorAll('.ai-upcoming-games-content-{{ ai_gen_id }}');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.tabs.forEach((tab) => {
          tab.addEventListener('click', () => {
            const targetTab = tab.getAttribute('data-tab');
            this.switchTab(targetTab);
          });
        });
      }

      switchTab(targetTab) {
        this.tabs.forEach((tab) => {
          const isActive = tab.getAttribute('data-tab') === targetTab;
          tab.classList.toggle('active', isActive);
          tab.setAttribute('aria-selected', isActive);
        });

        this.panels.forEach((panel) => {
          const panelId = panel.getAttribute('id');
          const isActive = panelId.includes(targetTab);
          panel.classList.toggle('active', isActive);
        });
      }
    }

    customElements.define('upcoming-games-{{ ai_gen_id }}', UpcomingGames{{ ai_gen_id }});
  })();
</script>

