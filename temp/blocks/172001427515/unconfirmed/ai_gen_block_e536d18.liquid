{% doc %}
  @prompt
    A section to display our upcoming games with a tab that leads to the games tab. , I mean our video games that we have on steam, Make it just upcoming games as we have no games out yet 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-steam-games-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-steam-games-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-steam-games-header-{{ ai_gen_id }} {
    margin-bottom: 30px;
  }

  .ai-steam-games-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 10px 0;
    font-weight: 700;
  }

  .ai-steam-games-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
  }

  .ai-steam-games-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 24px;
  }

  .ai-steam-game-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .ai-steam-game-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
  }

  .ai-steam-game-image-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    position: relative;
  }

  .ai-steam-game-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-steam-game-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #1b2838;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-steam-game-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-steam-game-status-{{ ai_gen_id }} {
    position: absolute;
    top: 12px;
    right: 12px;
    padding: 6px 12px;
    border-radius: 4px;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    background-color: {{ block.settings.upcoming_badge_color }};
    color: {{ block.settings.upcoming_badge_text_color }};
  }

  .ai-steam-game-info-{{ ai_gen_id }} {
    padding: 20px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .ai-steam-game-name-{{ ai_gen_id }} {
    font-size: {{ block.settings.game_title_size }}px;
    color: {{ block.settings.game_title_color }};
    margin: 0 0 8px 0;
    font-weight: 600;
  }

  .ai-steam-game-release-{{ ai_gen_id }} {
    font-size: {{ block.settings.game_date_size }}px;
    color: {{ block.settings.game_date_color }};
    margin: 0 0 12px 0;
    font-weight: 500;
  }

  .ai-steam-game-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.game_description_size }}px;
    color: {{ block.settings.game_description_color }};
    line-height: 1.5;
    margin: 0 0 16px 0;
    flex-grow: 1;
  }

  .ai-steam-game-link-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: 4px;
    font-size: 14px;
    font-weight: 600;
    transition: background-color 0.3s ease;
    align-self: flex-start;
  }

  .ai-steam-game-link-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-steam-games-empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #999;
    font-size: 16px;
  }

  @media screen and (max-width: 749px) {
    .ai-steam-games-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }
  }
{% endstyle %}

<div class="ai-steam-games-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-steam-games-container-{{ ai_gen_id }}">
    {% if block.settings.title != blank or block.settings.subtitle != blank %}
      <div class="ai-steam-games-header-{{ ai_gen_id }}">
        {% if block.settings.title != blank %}
          <h2 class="ai-steam-games-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
        {% endif %}
        {% if block.settings.subtitle != blank %}
          <p class="ai-steam-games-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
        {% endif %}
      </div>
    {% endif %}

    {% assign has_games = false %}
    <div class="ai-steam-games-grid-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign game_enabled_key = 'game_' | append: i | append: '_enabled'
          assign game_name_key = 'game_' | append: i | append: '_name'
          assign game_release_key = 'game_' | append: i | append: '_release_date'
          assign game_description_key = 'game_' | append: i | append: '_description'
          assign game_image_key = 'game_' | append: i | append: '_image'
          assign game_steam_link_key = 'game_' | append: i | append: '_steam_link'

          assign game_enabled = block.settings[game_enabled_key]
          assign game_name = block.settings[game_name_key]
          assign game_release = block.settings[game_release_key]
          assign game_description = block.settings[game_description_key]
          assign game_image = block.settings[game_image_key]
          assign game_steam_link = block.settings[game_steam_link_key]
        %}

        {% if game_enabled %}
          {% assign has_games = true %}
          <div class="ai-steam-game-card-{{ ai_gen_id }}">
            <div class="ai-steam-game-image-{{ ai_gen_id }}">
              {% if game_image %}
                <img
                  src="{{ game_image | image_url: width: 600 }}"
                  alt="{{ game_name | escape }}"
                  loading="lazy"
                  width="600"
                  height="338"
                >
              {% else %}
                <div class="ai-steam-game-image-placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
              <span class="ai-steam-game-status-{{ ai_gen_id }}">Coming Soon</span>
            </div>
            <div class="ai-steam-game-info-{{ ai_gen_id }}">
              {% if game_name != blank %}
                <h3 class="ai-steam-game-name-{{ ai_gen_id }}">{{ game_name }}</h3>
              {% endif %}
              {% if game_release != blank %}
                <p class="ai-steam-game-release-{{ ai_gen_id }}">Release Date: {{ game_release }}</p>
              {% endif %}
              {% if game_description != blank %}
                <div class="ai-steam-game-description-{{ ai_gen_id }}">{{ game_description }}</div>
              {% endif %}
              {% if game_steam_link != blank %}
                <a href="{{ game_steam_link }}" class="ai-steam-game-link-{{ ai_gen_id }}" target="_blank" rel="noopener">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                  </svg>
                  View on Steam
                </a>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
    {% unless has_games %}
      <div class="ai-steam-games-empty-{{ ai_gen_id }}">
        No upcoming games at the moment. Stay tuned for announcements!
      </div>
    {% endunless %}
  </div>
</div>

