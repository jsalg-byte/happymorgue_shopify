{% doc %}
  @prompt
    Make a button that says upcoming events and to the right of it is a movie poster flier where I can insert the upcoming event flier we are promoting. Make it very minimal and clean., Make it more like a small movie poster slot like the past events section not so big to cover the whole space 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-event-promo-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-event-promo__container-{{ ai_gen_id }} {
    display: flex;
    align-items: flex-start;
    gap: {{ block.settings.gap }}px;
    max-width: max-content;
  }

  .ai-event-promo__button-{{ ai_gen_id }} {
    padding: {{ block.settings.button_padding }}px {{ block.settings.button_padding | times: 1.5 }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    text-decoration: none;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 500;
    white-space: nowrap;
    transition: all 0.2s ease;
    display: inline-flex;
    align-items: center;
    height: fit-content;
  }

  .ai-event-promo__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  .ai-event-promo__poster-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.poster_width }}px;
    flex-shrink: 0;
  }

  .ai-event-promo__poster-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-event-promo__poster-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: {{ block.settings.poster_aspect_ratio }};
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-event-promo__poster-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-event-promo__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 12px;
    left: 50%;
    transform: translateX(-50%);
    padding: 8px 12px;
    font-size: 12px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-event-promo__container-{{ ai_gen_id }} {
      flex-direction: column;
      gap: {{ block.settings.gap | times: 0.75 }}px;
    }

    .ai-event-promo__button-{{ ai_gen_id }} {
      width: 100%;
      justify-content: center;
    }

    .ai-event-promo__poster-wrapper-{{ ai_gen_id }} {
      width: 100%;
      max-width: {{ block.settings.poster_width }}px;
    }
  }
{% endstyle %}

<div class="ai-event-promo-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-event-promo__container-{{ ai_gen_id }}">
    <a href="{{ block.settings.button_link }}" class="ai-event-promo__button-{{ ai_gen_id }}">
      {{ block.settings.button_text }}
    </a>

    <div class="ai-event-promo__poster-wrapper-{{ ai_gen_id }}">
      {% if block.settings.poster_image %}
        <img
          src="{{ block.settings.poster_image | image_url: width: 600 }}"
          alt="{{ block.settings.poster_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.poster_image.width }}"
          height="{{ block.settings.poster_image.height }}"
          class="ai-event-promo__poster-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-event-promo__poster-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-event-promo__empty-state-{{ ai_gen_id }}">
            Add event flier
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Event promo",
  "settings": [
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Upcoming events"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "button_font_size",
      "label": "Font size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "button_padding",
      "label": "Padding",
      "min": 6,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 10
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_bg_color",
      "label": "Hover background color",
      "default": "#d80000"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Hover text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "button_border_width",
      "label": "Border width",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "color",
      "id": "button_border_color",
      "label": "Border color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Poster"
    },
    {
      "type": "image_picker",
      "id": "poster_image",
      "label": "Event flier image"
    },
    {
      "type": "range",
      "id": "poster_width",
      "label": "Poster width",
      "min": 100,
      "max": 400,
      "step": 20,
      "unit": "px",
      "default": 200
    },
    {
      "type": "select",
      "id": "poster_aspect_ratio",
      "label": "Placeholder aspect ratio",
      "options": [
        {
          "value": "2/3",
          "label": "Portrait (2:3)"
        },
        {
          "value": "3/4",
          "label": "Portrait (3:4)"
        },
        {
          "value": "1/1",
          "label": "Square"
        },
        {
          "value": "4/3",
          "label": "Landscape (4:3)"
        }
      ],
      "default": "2/3"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Space between elements",
      "min": 12,
      "max": 48,
      "step": 4,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Event promo"
    }
  ]
}
{% endschema %}
