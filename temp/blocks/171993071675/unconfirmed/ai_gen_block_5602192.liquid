{% doc %}
  @prompt
    Make a button that says upcoming events and to the right of it is a movie poster flier where I can insert the upcoming event flier we are promoting. Make it very minimal and clean., Make it more like a small movie poster slot like the past events section not so big to cover the whole space , Ok perfect but make it on the right side make the upcoming events button lead to the events page and add on the left a title we can edit with a description box we can edit to add the name of the event and the description and add a box under that that’s says buy tickets that we can link directly to a external link., No you did it wrong. Make the title and description on the left side even to the flier that should be on the right side in a editorial magazine type of aesthetic 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-event-promo-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-event-promo__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: {{ block.settings.gap }}px;
    align-items: center;
    max-width: max-content;
  }

  .ai-event-promo__left-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.content_gap }}px;
  }

  .ai-event-promo__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    font-weight: 600;
    color: {{ block.settings.title_color }};
    margin: 0;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .ai-event-promo__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_font_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.6;
    margin: 0;
    max-width: 400px;
  }

  .ai-event-promo__buttons-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.button_gap }}px;
    margin-top: {{ block.settings.buttons_top_margin }}px;
  }

  .ai-event-promo__button-{{ ai_gen_id }} {
    padding: {{ block.settings.button_padding }}px {{ block.settings.button_padding | times: 2 }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    text-decoration: none;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 500;
    transition: all 0.2s ease;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .ai-event-promo__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  .ai-event-promo__right-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.right_gap }}px;
  }

  .ai-event-promo__poster-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.poster_width }}px;
  }

  .ai-event-promo__poster-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-event-promo__poster-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: {{ block.settings.poster_aspect_ratio }};
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-event-promo__poster-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-event-promo__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 12px;
    left: 50%;
    transform: translateX(-50%);
    padding: 8px 12px;
    font-size: 12px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-event-promo__container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.gap | times: 0.75 }}px;
    }

    .ai-event-promo__buttons-{{ ai_gen_id }} {
      flex-direction: row;
      flex-wrap: wrap;
    }

    .ai-event-promo__poster-wrapper-{{ ai_gen_id }} {
      width: 100%;
      max-width: {{ block.settings.poster_width }}px;
    }
  }
{% endstyle %}

<div class="ai-event-promo-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-event-promo__container-{{ ai_gen_id }}">
    <div class="ai-event-promo__left-{{ ai_gen_id }}">
      {% if block.settings.event_title != blank %}
        <h2 class="ai-event-promo__title-{{ ai_gen_id }}">{{ block.settings.event_title }}</h2>
      {% endif %}

      {% if block.settings.event_description != blank %}
        <div class="ai-event-promo__description-{{ ai_gen_id }}">
          {{ block.settings.event_description }}
        </div>
      {% endif %}

      <div class="ai-event-promo__buttons-{{ ai_gen_id }}">
        <a href="{{ block.settings.tickets_link }}" class="ai-event-promo__button-{{ ai_gen_id }}">
          {{ block.settings.tickets_button_text }}
        </a>

        <a href="{{ block.settings.events_page_link }}" class="ai-event-promo__button-{{ ai_gen_id }}">
          {{ block.settings.events_button_text }}
        </a>
      </div>
    </div>

    <div class="ai-event-promo__right-{{ ai_gen_id }}">
      <div class="ai-event-promo__poster-wrapper-{{ ai_gen_id }}">
        {% if block.settings.poster_image %}
          <img
            src="{{ block.settings.poster_image | image_url: width: 600 }}"
            alt="{{ block.settings.poster_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.poster_image.width }}"
            height="{{ block.settings.poster_image.height }}"
            class="ai-event-promo__poster-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-event-promo__poster-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="ai-event-promo__empty-state-{{ ai_gen_id }}">
              Add event flier
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Event promo",
  "settings": [
    {
      "type": "header",
      "content": "Event details"
    },
    {
      "type": "text",
      "id": "event_title",
      "label": "Event title",
      "default": "Live music night"
    },
    {
      "type": "textarea",
      "id": "event_description",
      "label": "Event description",
      "default": "Join us for an unforgettable evening of live music and entertainment."
    },
    {
      "type": "range",
      "id": "title_font_size",
      "label": "Title font size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "description_font_size",
      "label": "Description font size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#666666"
    },
    {
      "type": "header",
      "content": "Buy tickets button"
    },
    {
      "type": "text",
      "id": "tickets_button_text",
      "label": "Button text",
      "default": "Buy tickets"
    },
    {
      "type": "url",
      "id": "tickets_link",
      "label": "Tickets link"
    },
    {
      "type": "header",
      "content": "Events page button"
    },
    {
      "type": "text",
      "id": "events_button_text",
      "label": "Button text",
      "default": "Upcoming events"
    },
    {
      "type": "url",
      "id": "events_page_link",
      "label": "Events page link"
    },
    {
      "type": "header",
      "content": "Button style"
    },
    {
      "type": "range",
      "id": "button_font_size",
      "label": "Font size",
      "min": 10,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "button_padding",
      "label": "Padding",
      "min": 6,
      "max": 16,
      "step": 2,
      "unit": "px",
      "default": 10
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_bg_color",
      "label": "Hover background color",
      "default": "#d80000"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Hover text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "button_border_width",
      "label": "Border width",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "color",
      "id": "button_border_color",
      "label": "Border color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Poster"
    },
    {
      "type": "image_picker",
      "id": "poster_image",
      "label": "Event flier image"
    },
    {
      "type": "range",
      "id": "poster_width",
      "label": "Poster width",
      "min": 120,
      "max": 400,
      "step": 20,
      "unit": "px",
      "default": 240
    },
    {
      "type": "select",
      "id": "poster_aspect_ratio",
      "label": "Placeholder aspect ratio",
      "options": [
        {
          "value": "2/3",
          "label": "Portrait (2:3)"
        },
        {
          "value": "3/4",
          "label": "Portrait (3:4)"
        },
        {
          "value": "1/1",
          "label": "Square"
        },
        {
          "value": "4/3",
          "label": "Landscape (4:3)"
        }
      ],
      "default": "2/3"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Space between left and right",
      "min": 20,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "content_gap",
      "label": "Space between title and description",
      "min": 8,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "buttons_top_margin",
      "label": "Space above buttons",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "button_gap",
      "label": "Space between buttons",
      "min": 6,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "right_gap",
      "label": "Space in right column",
      "min": 8,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 12
    }
  ],
  "presets": [
    {
      "name": "Event promo"
    }
  ]
}
{% endschema %}
