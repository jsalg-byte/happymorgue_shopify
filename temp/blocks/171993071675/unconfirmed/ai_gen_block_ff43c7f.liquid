{% doc %}
  @prompt
    Make a button that says upcoming events and to the right of it is a movie poster flier where I can insert the upcoming event flier we are promoting. Make it very minimal and clean., Make it more like a small movie poster slot like the past events section not so big to cover the whole space , Ok perfect but make it on the right side make the upcoming events button lead to the events page and add on the left a title we can edit with a description box we can edit to add the name of the event and the description and add a box under that that’s says buy tickets that we can link directly to a external link., No you did it wrong. Make the title and description on the left side even to the flier that should be on the right side in a editorial magazine type of aesthetic , Ok just start over. Make the event flier in the middle. Add the upcoming events on top of of the flier. Add the buy tickets option under the flier. Don’t make the flier big keep it the same size it is now. Allow the buy tickets button to be linked to an external website. And the upcoming events button be linked to our events tab 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-event-flier-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-event-flier__container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: {{ block.settings.spacing }}px;
    max-width: max-content;
    margin: 0 auto;
  }

  .ai-event-flier__button-{{ ai_gen_id }} {
    padding: {{ block.settings.button_padding }}px {{ block.settings.button_padding | times: 2 }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    text-decoration: none;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 500;
    transition: all 0.2s ease;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .ai-event-flier__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  .ai-event-flier__poster-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.poster_width }}px;
  }

  .ai-event-flier__poster-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-event-flier__poster-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: {{ block.settings.poster_aspect_ratio }};
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-event-flier__poster-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-event-flier__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 12px;
    left: 50%;
    transform: translateX(-50%);
    padding: 8px 12px;
    font-size: 12px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-event-flier__poster-wrapper-{{ ai_gen_id }} {
      width: 100%;
      max-width: {{ block.settings.poster_width }}px;
    }
  }
{% endstyle %}

<div class="ai-event-flier-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-event-flier__container-{{ ai_gen_id }}">
    <a href="{{ block.settings.events_page_link }}" class="ai-event-flier__button-{{ ai_gen_id }}">
      {{ block.settings.events_button_text }}
    </a>

    <div class="ai-event-flier__poster-wrapper-{{ ai_gen_id }}">
      {% if block.settings.poster_image %}
        <img
          src="{{ block.settings.poster_image | image_url: width: 600 }}"
          alt="{{ block.settings.poster_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.poster_image.width }}"
          height="{{ block.settings.poster_image.height }}"
          class="ai-event-flier__poster-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-event-flier__poster-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-event-flier__empty-state-{{ ai_gen_id }}">
            Add event flier
          </div>
        </div>
      {% endif %}
    </div>

    <a href="{{ block.settings.tickets_link }}" class="ai-event-flier__button-{{ ai_gen_id }}">
      {{ block.settings.tickets_button_text }}
    </a>
  </div>
</div>

{% schema %}
{
  "name": "Event flier",
  "settings": [
    {
      "type": "header",
      "content": "Flier"
    },
    {
      "type": "image_picker",
      "id": "poster_image",
      "label": "Event flier image"
    },
    {
      "type": "range",
      "id": "poster_width",
      "label": "Flier width",
      "min": 120,
      "max": 400,
      "step": 20,
      "unit": "px",
      "default": 240
    },
    {
      "type": "select",
      "id": "poster_aspect_ratio",
      "label": "Placeholder aspect ratio",
      "options": [
        {
          "value": "2/3",
          "label": "Portrait (2:3)"
        },
        {
          "value": "3/4",
          "label": "Portrait (3:4)"
        },
        {
          "value": "1/1",
          "label": "Square"
        },
        {
          "value": "4/3",
          "label": "Landscape (4:3)"
        }
      ],
      "default": "2/3"
    },
    {
      "type": "header",
      "content": "Upcoming events button"
    },
    {
      "type": "text",
      "id": "events_button_text",
      "label": "Button text",
      "default": "Upcoming events"
    },
    {
      "type": "url",
      "id": "events_page_link",
      "label": "Events page link"
    },
    {
      "type": "header",
      "content": "Buy tickets button"
    },
    {
      "type": "text",
      "id": "tickets_button_text",
      "label": "Button text",
      "default": "Buy tickets"
    },
    {
      "type": "url",
      "id": "tickets_link",
      "label": "Tickets link"
    },
    {
      "type": "header",
      "content": "Button style"
    },
    {
      "type": "range",
      "id": "button_font_size",
      "label": "Font size",
      "min": 10,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "button_padding",
      "label": "Padding",
      "min": 6,
      "max": 16,
      "step": 2,
      "unit": "px",
      "default": 10
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_bg_color",
      "label": "Hover background color",
      "default": "#d80000"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Hover text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "button_border_width",
      "label": "Border width",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "color",
      "id": "button_border_color",
      "label": "Border color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "spacing",
      "label": "Space between elements",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 16
    }
  ],
  "presets": [
    {
      "name": "Event flier"
    }
  ]
}
{% endschema %}
