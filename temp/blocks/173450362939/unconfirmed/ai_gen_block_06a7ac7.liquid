        <span class="ai-matrix-player__track-name-{{ ai_gen_id }}">{{ block.settings.track_9_name }}</span>
        <span class="ai-matrix-player__track-duration-{{ ai_gen_id }}">--:--</span>
      </div>
    {% endif %}

    {% if block.settings.track_10_url != blank %}
