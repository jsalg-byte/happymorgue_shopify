<script>
  (function() {
    class MatrixPlayer{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.audio = new Audio();
        this.currentTrackIndex = 0;
        this.tracks = [];
        this.isPlaying = false;
        this.audioContext = null;
        this.analyser = null;
        this.dataArray = null;
        this.autoplay = {{ block.settings.autoplay }};
      }

      connectedCallback() {
        this.initElements();
        this.loadTracks();
        this.setupEventListeners();
        this.setupVisualizer();

        if (this.tracks.length > 0 && this.autoplay) {
          this.loadTrack(0);
          setTimeout(() => {
            this.play();
          }, 500);
        }
      }

      initElements() {
        this.playPauseBtn = this.querySelector('#play-pause-{{ ai_gen_id }}');
        this.prevBtn = this.querySelector('#prev-{{ ai_gen_id }}');
        this.nextBtn = this.querySelector('#next-{{ ai_gen_id }}');
        this.progressBar = this.querySelector('#progress-bar-{{ ai_gen_id }}');
        this.progress = this.querySelector('#progress-{{ ai_gen_id }}');
        this.timeDisplay = this.querySelector('#time-display-{{ ai_gen_id }}');
        this.volumeBar = this.querySelector('#volume-bar-{{ ai_gen_id }}');
        this.volumeControl = this.querySelector('#volume-{{ ai_gen_id }}');
        this.playlist = this.querySelector('#playlist-{{ ai_gen_id }}');
        this.canvas = this.querySelector('#visualizer-{{ ai_gen_id }}');
        this.canvasCtx = this.canvas.getContext('2d');
      }

      loadTracks() {
        const trackElements = this.querySelectorAll('.ai-matrix-player__track-{{ ai_gen_id }}');
        trackElements.forEach((el, index) => {
          const url = el.getAttribute('data-url');
          const name = el.querySelector('.ai-matrix-player__track-name-{{ ai_gen_id }}').textContent;
          if (url) {
            this.tracks.push({ url, name, element: el });
          }
        });
      }

      setupEventListeners() {
        this.playPauseBtn.addEventListener('click', () => this.togglePlayPause());
        this.prevBtn.addEventListener('click', () => this.previousTrack());
        this.nextBtn.addEventListener('click', () => this.nextTrack());

        this.progress.addEventListener('click', (e) => this.seek(e));
        this.volumeControl.addEventListener('click', (e) => this.setVolume(e));

        this.audio.addEventListener('timeupdate', () => this.updateProgress());
        this.audio.addEventListener('ended', () => this.nextTrack());
        this.audio.addEventListener('loadedmetadata', () => this.updateDuration());

        this.tracks.forEach((track, index) => {
          track.element.addEventListener('click', () => this.loadTrack(index));
        });
      }

      setupVisualizer() {
        this.canvas.width = this.canvas.offsetWidth;
        this.canvas.height = this.canvas.offsetHeight;

        if (!this.audioContext) {
          this.audioContext = new (window.AudioContext || window.webkitAudioContext)();
          this.analyser = this.audioContext.createAnalyser();
          this.analyser.fftSize = 128;
          const source = this.audioContext.createMediaElementSource(this.audio);
          source.connect(this.analyser);
          this.analyser.connect(this.audioContext.destination);
          this.dataArray = new Uint8Array(this.analyser.frequencyBinCount);
        }

        this.drawVisualizer();
      }

      drawVisualizer() {
        requestAnimationFrame(() => this.drawVisualizer());

        const width = this.canvas.width;
        const height = this.canvas.height;
        const barWidth = (width / this.analyser.frequencyBinCount) * 2.5;

        this.analyser.getByteFrequencyData(this.dataArray);

        this.canvasCtx.fillStyle = '#000000';
        this.canvasCtx.fillRect(0, 0, width, height);

        let x = 0;
        for (let i = 0; i < this.analyser.frequencyBinCount; i++) {
          const barHeight = (this.dataArray[i] / 255) * height;
          const red = Math.min(255, this.dataArray[i] + 100);
          this.canvasCtx.fillStyle = `rgb(${red}, 0, 0)`;
          this.canvasCtx.fillRect(x, height - barHeight, barWidth, barHeight);
          x += barWidth + 1;
        }
      }

      loadTrack(index) {
        if (index < 0 || index >= this.tracks.length) return;

        this.currentTrackIndex = index;
        this.audio.src = this.tracks[index].url;
        this.audio.volume = 0.7;

        this.tracks.forEach((track, i) => {
          if (i === index) {
            track.element.classList.add('active');
          } else {
            track.element.classList.remove('active');
          }
        });

        if (this.isPlaying) {
          this.audio.play();
        }
      }

      togglePlayPause() {
        if (this.tracks.length === 0) return;

        if (this.isPlaying) {
          this.pause();
        } else {
          this.play();
        }
      }

      play() {
        if (this.tracks.length === 0) return;

        if (!this.audio.src) {
          this.loadTrack(0);
        }

        if (this.audioContext && this.audioContext.state === 'suspended') {
          this.audioContext.resume();
        }

        this.audio.play();
        this.isPlaying = true;
        this.playPauseBtn.textContent = '❚❚';
      }

      pause() {
        this.audio.pause();
        this.isPlaying = false;
        this.playPauseBtn.textContent = '►';
      }

      nextTrack() {
        const nextIndex = (this.currentTrackIndex + 1) % this.tracks.length;
        this.loadTrack(nextIndex);
        if (this.isPlaying) {
          this.audio.play();
        }
      }

      previousTrack() {
        const prevIndex = this.currentTrackIndex === 0 ? this.tracks.length - 1 : this.currentTrackIndex - 1;
        this.loadTrack(prevIndex);
        if (this.isPlaying) {
          this.audio.play();
        }
      }

      seek(e) {
        const rect = this.progress.getBoundingClientRect();
        const percent = (e.clientX - rect.left) / rect.width;
        this.audio.currentTime = percent * this.audio.duration;
      }

      setVolume(e) {
        const rect = this.volumeControl.getBoundingClientRect();
        const percent = (e.clientX - rect.left) / rect.width;
        this.audio.volume = Math.max(0, Math.min(1, percent));
        this.volumeBar.style.width = (percent * 100) + '%';
      }

      updateProgress() {
        if (this.audio.duration) {
          const percent = (this.audio.currentTime / this.audio.duration) * 100;
          this.progressBar.style.width = percent + '%';

          const current = this.formatTime(this.audio.currentTime);
          this.timeDisplay.textContent = current;
        }
      }

      updateDuration() {
        const trackElement = this.tracks[this.currentTrackIndex].element;
        const durationElement = trackElement.querySelector('.ai-matrix-player__track-duration-{{ ai_gen_id }}');
        durationElement.textContent = this.formatTime(this.audio.duration);
      }

      formatTime(seconds) {
        if (isNaN(seconds)) return '0:00';
        const mins = Math.floor(seconds / 60);
        const secs = Math.floor(seconds % 60);
        return `${mins}:${secs.toString().padStart(2, '0')}`;
      }
    }

    customElements.define('matrix-player-{{ ai_gen_id }}', MatrixPlayer{{ ai_gen_id }});
  })();
</script>

