{% doc %}
  @prompt
    Make a mp3 player that lets me add an unlimited amount of tracks. Make it look very early 90s matrix like and make the music auto play when you visit the website. Maybe add a visualizer screen that’s red that moves with the music being played., Make it smaller and more minimal like how MySpace had it 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-matrix-player-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    background: #000000;
    border: 1px solid #00ff00;
    font-family: 'Courier New', monospace;
    padding: 0;
    position: relative;
    box-shadow: 0 0 10px rgba(0, 255, 0, 0.2);
  }

  .ai-matrix-player__header-{{ ai_gen_id }} {
    background: #001100;
    border-bottom: 1px solid #00ff00;
    padding: 6px 10px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .ai-matrix-player__title-{{ ai_gen_id }} {
    color: #00ff00;
    font-size: 11px;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 1px;
    text-shadow: 0 0 5px #00ff00;
  }

  .ai-matrix-player__visualizer-container-{{ ai_gen_id }} {
    background: #000000;
    border-bottom: 1px solid #ff0000;
    padding: 8px;
    height: {{ block.settings.visualizer_height }}px;
    position: relative;
    overflow: hidden;
  }

  .ai-matrix-player__visualizer-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background: #000000;
    border: 1px solid #ff0000;
    box-shadow: 0 0 8px rgba(255, 0, 0, 0.4), inset 0 0 8px rgba(255, 0, 0, 0.1);
  }

  .ai-matrix-player__controls-{{ ai_gen_id }} {
    background: #001100;
    border-bottom: 1px solid #00ff00;
    padding: 8px;
    display: flex;
    gap: 6px;
    align-items: center;
    flex-wrap: wrap;
  }

  .ai-matrix-player__button-{{ ai_gen_id }} {
    background: #000000;
    border: 1px solid #00ff00;
    color: #00ff00;
    padding: 4px 10px;
    font-family: 'Courier New', monospace;
    font-size: 10px;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: all 0.2s;
    text-shadow: 0 0 3px #00ff00;
  }

  .ai-matrix-player__button-{{ ai_gen_id }}:hover {
    background: #00ff00;
    color: #000000;
    text-shadow: none;
  }

  .ai-matrix-player__button-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-matrix-player__progress-container-{{ ai_gen_id }} {
    flex: 1;
    min-width: 120px;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .ai-matrix-player__progress-{{ ai_gen_id }} {
    flex: 1;
    height: 6px;
    background: #001100;
    border: 1px solid #00ff00;
    cursor: pointer;
    position: relative;
  }

  .ai-matrix-player__progress-bar-{{ ai_gen_id }} {
    height: 100%;
    background: #00ff00;
    width: 0%;
    box-shadow: 0 0 5px rgba(0, 255, 0, 0.6);
  }

  .ai-matrix-player__time-display-{{ ai_gen_id }} {
    color: #00ff00;
    font-size: 9px;
    min-width: 60px;
    text-align: right;
    text-shadow: 0 0 3px #00ff00;
  }

  .ai-matrix-player__volume-container-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .ai-matrix-player__volume-label-{{ ai_gen_id }} {
    color: #00ff00;
    font-size: 9px;
    text-shadow: 0 0 3px #00ff00;
  }

  .ai-matrix-player__volume-{{ ai_gen_id }} {
    width: 50px;
    height: 6px;
    background: #001100;
    border: 1px solid #00ff00;
    cursor: pointer;
    position: relative;
  }

  .ai-matrix-player__volume-bar-{{ ai_gen_id }} {
    height: 100%;
    background: #00ff00;
    width: 70%;
    box-shadow: 0 0 5px rgba(0, 255, 0, 0.6);
  }

  .ai-matrix-player__playlist-{{ ai_gen_id }} {
    background: #000000;
    max-height: 150px;
    overflow-y: auto;
  }

  .ai-matrix-player__track-{{ ai_gen_id }} {
    padding: 6px 10px;
    border-bottom: 1px solid #002200;
    color: #00ff00;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: all 0.2s;
    font-size: 11px;
  }

  .ai-matrix-player__track-{{ ai_gen_id }}:hover {
    background: #001a00;
    border-left: 2px solid #00ff00;
    padding-left: 8px;
  }

  .ai-matrix-player__track-{{ ai_gen_id }}.active {
    background: #002200;
    border-left: 2px solid #00ff00;
    padding-left: 8px;
  }

  .ai-matrix-player__track-name-{{ ai_gen_id }} {
    font-size: 11px;
    text-shadow: 0 0 3px #00ff00;
  }

  .ai-matrix-player__track-duration-{{ ai_gen_id }} {
    font-size: 9px;
    opacity: 0.7;
  }

  .ai-matrix-player__empty-{{ ai_gen_id }} {
    padding: 20px;
    text-align: center;
    color: #00ff00;
    font-size: 10px;
    opacity: 0.5;
    text-shadow: 0 0 3px #00ff00;
  }

  .ai-matrix-player__playlist-{{ ai_gen_id }}::-webkit-scrollbar {
    width: 8px;
  }

  .ai-matrix-player__playlist-{{ ai_gen_id }}::-webkit-scrollbar-track {
    background: #000000;
    border-left: 1px solid #002200;
  }

  .ai-matrix-player__playlist-{{ ai_gen_id }}::-webkit-scrollbar-thumb {
    background: #00ff00;
    box-shadow: 0 0 3px rgba(0, 255, 0, 0.5);
  }

  @media screen and (max-width: 749px) {
    .ai-matrix-player__controls-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-matrix-player__progress-container-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-matrix-player__volume-container-{{ ai_gen_id }} {
      width: 100%;
      justify-content: center;
    }
  }
{% endstyle %}

<matrix-player-{{ ai_gen_id }} class="ai-matrix-player-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
