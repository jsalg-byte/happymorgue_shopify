    <button class="ai-matrix-player__button-{{ ai_gen_id }}" id="play-pause-{{ ai_gen_id }}" aria-label="Play or pause">
      ►
    </button>
    <button class="ai-matrix-player__button-{{ ai_gen_id }}" id="next-{{ ai_gen_id }}" aria-label="Next track">
      ►►
    </button>

    <div class="ai-matrix-player__progress-container-{{ ai_gen_id }}">
      <div class="ai-matrix-player__progress-{{ ai_gen_id }}" id="progress-{{ ai_gen_id }}">
        <div class="ai-matrix-player__progress-bar-{{ ai_gen_id }}" id="progress-bar-{{ ai_gen_id }}"></div>
      </div>
      <div class="ai-matrix-player__time-display-{{ ai_gen_id }}" id="time-display-{{ ai_gen_id }}">0:00</div>
    </div>

    <div class="ai-matrix-player__volume-container-{{ ai_gen_id }}">
      <span class="ai-matrix-player__volume-label-{{ ai_gen_id }}">VOL</span>
      <div class="ai-matrix-player__volume-{{ ai_gen_id }}" id="volume-{{ ai_gen_id }}">
        <div class="ai-matrix-player__volume-bar-{{ ai_gen_id }}" id="volume-bar-{{ ai_gen_id }}"></div>
      </div>
