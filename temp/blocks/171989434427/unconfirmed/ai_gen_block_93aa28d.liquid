{% doc %}
  @prompt
    A side scrolling lay out for our shop products very minimal and clean , Can you make the navigation circles invisibles , No it needs to side scroll with a very minimal navigation look underneath. So I can scroll thru the products 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-scroll-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-product-scroll-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-product-scroll-header-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.header_spacing }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-product-scroll-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 8px 0;
    font-weight: 600;
  }

  .ai-product-scroll-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.text_color }};
    opacity: 0.8;
    margin: 0;
  }

  .ai-product-scroll-wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  .ai-product-scroll-track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.product_gap }}px;
    overflow-x: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding: {{ block.settings.track_padding }}px 0;
  }

  .ai-product-scroll-track-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-product-card-{{ ai_gen_id }} {
    flex: 0 0 {{ block.settings.card_width }}px;
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_radius }}px;
    overflow: hidden;
    text-decoration: none;
    display: block;
  }

  .ai-product-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: {{ block.settings.image_ratio }};
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-product-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-product-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-product-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-product-info-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
  }

  .ai-product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_title_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 8px 0;
    font-weight: 500;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .ai-product-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_price_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-product-scroll-dots-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.dot_spacing }}px;
    justify-content: {{ block.settings.nav_position }};
    margin-top: {{ block.settings.nav_spacing }}px;
    padding: 0 20px;
  }

  .ai-product-scroll-dot-{{ ai_gen_id }} {
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    opacity: {{ block.settings.dot_opacity | divided_by: 100.0 }};
    border: none;
    padding: 0;
    cursor: pointer;
    transition: opacity 0.3s ease;
  }

  .ai-product-scroll-dot-{{ ai_gen_id }}.active {
    opacity: 1;
  }

  .ai-product-scroll-dot-{{ ai_gen_id }}:hover {
    opacity: 0.8;
  }

  .ai-product-empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: {{ block.settings.text_color }};
    opacity: 0.6;
  }

  @media screen and (max-width: 749px) {
    .ai-product-card-{{ ai_gen_id }} {
      flex: 0 0 {{ block.settings.card_width_mobile }}px;
    }

    .ai-product-scroll-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<product-scroll-{{ ai_gen_id }} class="ai-product-scroll-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-product-scroll-container-{{ ai_gen_id }}">
    {% if block.settings.title != blank or block.settings.description != blank %}
      <div class="ai-product-scroll-header-{{ ai_gen_id }}">
        {% if block.settings.title != blank %}
          <h2 class="ai-product-scroll-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
        {% endif %}
        {% if block.settings.description != blank %}
          <p class="ai-product-scroll-description-{{ ai_gen_id }}">{{ block.settings.description }}</p>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.collection != blank %}
      <div class="ai-product-scroll-wrapper-{{ ai_gen_id }}">
        <div class="ai-product-scroll-track-{{ ai_gen_id }}" data-scroll-track>
          {% for product in block.settings.collection.products limit: block.settings.products_limit %}
            <a href="{{ product.url }}" class="ai-product-card-{{ ai_gen_id }}">
              <div class="ai-product-image-wrapper-{{ ai_gen_id }}">
                {% if product.featured_image %}
                  <img
                    src="{{ product.featured_image | image_url: width: 600 }}"
                    alt="{{ product.featured_image.alt | escape }}"
                    class="ai-product-image-{{ ai_gen_id }}"
                    loading="lazy"
                    width="600"
                    height="{{ 600 | divided_by: block.settings.image_ratio }}"
                  >
                {% else %}
                  <div class="ai-product-image-placeholder-{{ ai_gen_id }}">
                    {{ 'product-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>
              <div class="ai-product-info-{{ ai_gen_id }}">
                <h3 class="ai-product-title-{{ ai_gen_id }}">{{ product.title }}</h3>
                <p class="ai-product-price-{{ ai_gen_id }}">{{ product.price | money }}</p>
              </div>
            </a>
          {% endfor %}
        </div>
      </div>

      {% if block.settings.show_navigation %}
        <div class="ai-product-scroll-dots-{{ ai_gen_id }}" data-dots-container></div>
      {% endif %}
    {% else %}
      <div class="ai-product-empty-state-{{ ai_gen_id }}">
        <p>Select a collection to display products</p>
      </div>
    {% endif %}
  </div>
</product-scroll-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductScroll{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.track = this.querySelector('[data-scroll-track]');
        this.dotsContainer = this.querySelector('[data-dots-container]');

        if (!this.track) return;

        this.setupDots();
        this.updateActiveDot();

        this.track.addEventListener('scroll', () => {
          this.updateActiveDot();
        });
      }

      setupDots() {
        if (!this.dotsContainer) return;

        const cards = this.track.querySelectorAll('.ai-product-card-{{ ai_gen_id }}');
        const visibleCards = Math.floor(this.track.offsetWidth / (cards[0]?.offsetWidth || 1));
        const totalDots = Math.ceil(cards.length / visibleCards);

        for (let i = 0; i < totalDots; i++) {
          const dot = document.createElement('button');
          dot.className = 'ai-product-scroll-dot-{{ ai_gen_id }}';
          dot.setAttribute('aria-label', `Go to page ${i + 1}`);
          dot.addEventListener('click', () => {
            const scrollAmount = this.track.offsetWidth * i;
            this.track.scrollTo({
              left: scrollAmount,
              behavior: 'smooth'
            });
          });
          this.dotsContainer.appendChild(dot);
        }
      }

      updateActiveDot() {
        if (!this.dotsContainer) return;

        const dots = this.dotsContainer.querySelectorAll('.ai-product-scroll-dot-{{ ai_gen_id }}');
        const scrollPercentage = this.track.scrollLeft / (this.track.scrollWidth - this.track.offsetWidth);
        const activeDotIndex = Math.round(scrollPercentage * (dots.length - 1));

        dots.forEach((dot, index) => {
          if (index === activeDotIndex) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }
    }

    customElements.define('product-scroll-{{ ai_gen_id }}', ProductScroll{{ ai_gen_id }});
  })();
</script>

