      "default": 30
    },
    {
      "type": "range",
      "id": "scanline_spacing",
      "min": 1,
      "max": 10,
      "step": 1,
      "unit": "px",
      "label": "Spacing",
      "default": 2
    },
    {
      "type": "header",
      "content": "Film grain"
    },
    {
      "type": "range",
      "id": "grain_intensity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Intensity",
      "default": 40
    },
    {
      "type": "header",
      "content": "Color distortion"
    },
    {
      "type": "range",
      "id": "color_distortion",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Intensity",
      "default": 15
    },
    {
      "type": "range",
      "id": "color_shift_r",
      "min": 0,
      "max": 255,
      "step": 5,
      "label": "Red channel",
      "default": 255
    },
    {
      "type": "range",
      "id": "color_shift_g",
      "min": 0,
      "max": 255,
      "step": 5,
      "label": "Green channel",
      "default": 0
    },
    {
      "type": "range",
      "id": "color_shift_b",
      "min": 0,
      "max": 255,
      "step": 5,
      "label": "Blue channel",
      "default": 100
    },
    {
      "type": "header",
      "content": "Chromatic aberration"
    },
    {
      "type": "range",
      "id": "chromatic_aberration",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Intensity",
