{% doc %}
  @prompt
    A image slideshow with text on the bottom that scrolls from left to right 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-slideshow-container-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    overflow: hidden;
    display: block;
  }

  .ai-slideshow-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.slideshow_height }}px;
    overflow: hidden;
  }

  .ai-slideshow-slides-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .ai-slideshow-slide-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity {{ block.settings.transition_speed }}s ease-in-out;
  }

  .ai-slideshow-slide-{{ ai_gen_id }}.active {
    opacity: 1;
  }

  .ai-slideshow-slide-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-slideshow-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-slideshow-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-slideshow-nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: {{ block.settings.nav_button_color }};
    color: {{ block.settings.nav_button_icon_color }};
    border: none;
    width: {{ block.settings.nav_button_size }}px;
    height: {{ block.settings.nav_button_size }}px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    opacity: {{ block.settings.nav_button_opacity | divided_by: 100.0 }};
    transition: opacity 0.3s ease;
  }

  .ai-slideshow-nav-{{ ai_gen_id }}:hover {
    opacity: 1;
  }

  .ai-slideshow-nav-{{ ai_gen_id }}.prev {
    left: {{ block.settings.nav_button_offset }}px;
  }

  .ai-slideshow-nav-{{ ai_gen_id }}.next {
    right: {{ block.settings.nav_button_offset }}px;
  }

  .ai-slideshow-nav-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.nav_button_size }}px * 0.5);
    height: calc({{ block.settings.nav_button_size }}px * 0.5);
  }

  .ai-slideshow-dots-{{ ai_gen_id }} {
    position: absolute;
    bottom: {{ block.settings.text_height }}px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
    z-index: 10;
    padding: 10px;
  }

  .ai-slideshow-dot-{{ ai_gen_id }} {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    opacity: 0.5;
    cursor: pointer;
    border: none;
    padding: 0;
    transition: opacity 0.3s ease;
  }

  .ai-slideshow-dot-{{ ai_gen_id }}.active {
    opacity: 1;
  }

  .ai-slideshow-text-container-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: {{ block.settings.text_height }}px;
    background-color: {{ block.settings.text_background_color }};
    overflow: hidden;
    display: flex;
    align-items: center;
  }

  .ai-slideshow-text-track-{{ ai_gen_id }} {
    display: flex;
    white-space: nowrap;
    will-change: transform;
  }

  .ai-slideshow-text-item-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    padding: 0 {{ block.settings.text_spacing }}px;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    font-weight: {{ block.settings.text_weight }};
  }

  .ai-slideshow-text-separator-{{ ai_gen_id }} {
    display: inline-block;
    width: {{ block.settings.separator_size }}px;
    height: {{ block.settings.separator_size }}px;
    background-color: {{ block.settings.separator_color }};
    border-radius: 50%;
    margin: 0 {{ block.settings.text_spacing }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-slideshow-wrapper-{{ ai_gen_id }} {
      height: {{ block.settings.slideshow_height | times: 0.6 }}px;
    }

    .ai-slideshow-nav-{{ ai_gen_id }} {
      width: {{ block.settings.nav_button_size | times: 0.8 }}px;
      height: {{ block.settings.nav_button_size | times: 0.8 }}px;
    }

    .ai-slideshow-nav-{{ ai_gen_id }} svg {
      width: calc({{ block.settings.nav_button_size | times: 0.8 }}px * 0.5);
      height: calc({{ block.settings.nav_button_size | times: 0.8 }}px * 0.5);
    }

    .ai-slideshow-text-item-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<image-slideshow-{{ ai_gen_id }}
  class="ai-slideshow-container-{{ ai_gen_id }}"
  data-autoplay="{{ block.settings.autoplay }}"
  data-autoplay-speed="{{ block.settings.autoplay_speed }}"
  data-scroll-speed="{{ block.settings.scroll_speed }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-slideshow-wrapper-{{ ai_gen_id }}">
    <div class="ai-slideshow-slides-{{ ai_gen_id }}">
      {% for i in (1..5) %}
        {% liquid
          assign image_key = 'image_' | append: i
          assign image = block.settings[image_key]
        %}
        
        {% if image != blank %}
          <div class="ai-slideshow-slide-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}" data-slide-index="{{ forloop.index0 }}">
            <img
              src="{{ image | image_url: width: 2000 }}"
              alt="{{ image.alt | escape }}"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
              width="{{ image.width }}"
              height="{{ image.height }}"
            >
          </div>
        {% endif %}
      {% endfor %}

      {% assign has_images = false %}
      {% for i in (1..5) %}
        {% liquid
          assign image_key = 'image_' | append: i
          assign image = block.settings[image_key]
        %}
        {% if image != blank %}
          {% assign has_images = true %}
          {% break %}
        {% endif %}
      {% endfor %}

      {% unless has_images %}
        <div class="ai-slideshow-slide-{{ ai_gen_id }} active" data-slide-index="0">
          <div class="ai-slideshow-placeholder-{{ ai_gen_id }}">
            {{ 'hero-apparel-1' | placeholder_svg_tag }}
          </div>
        </div>
      {% endunless %}
    </div>

    {% if block.settings.show_navigation %}
      <button class="ai-slideshow-nav-{{ ai_gen_id }} prev" aria-label="Previous slide">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>
      <button class="ai-slideshow-nav-{{ ai_gen_id }} next" aria-label="Next slide">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    {% endif %}

    {% if block.settings.show_dots %}
      <div class="ai-slideshow-dots-{{ ai_gen_id }}">
        {% for i in (1..5) %}
          {% liquid
            assign image_key = 'image_' | append: i
            assign image = block.settings[image_key]
          %}
          {% if image != blank %}
            <button class="ai-slideshow-dot-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}" data-slide-index="{{ forloop.index0 }}" aria-label="Go to slide {{ forloop.index }}"></button>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}

    <div class="ai-slideshow-text-container-{{ ai_gen_id }}">
      <div class="ai-slideshow-text-track-{{ ai_gen_id }}">
        {% if block.settings.scrolling_text != blank %}
          {% for i in (1..20) %}
            <span class="ai-slideshow-text-item-{{ ai_gen_id }}">{{ block.settings.scrolling_text }}</span>
            <span class="ai-slideshow-text-separator-{{ ai_gen_id }}"></span>
          {% endfor %}
        {% else %}
          {% for i in (1..20) %}
            <span class="ai-slideshow-text-item-{{ ai_gen_id }}">Add your scrolling text here</span>
            <span class="ai-slideshow-text-separator-{{ ai_gen_id }}"></span>
          {% endfor %}
        {% endif %}
      </div>
    </div>
  </div>
</image-slideshow-{{ ai_gen_id }}>

<script>
  (function() {
    class ImageSlideshow{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.autoplayInterval = null;
        this.scrollAnimationFrame = null;
        this.scrollPosition = 0;
      }

      connectedCallback() {
        this.slides = this.querySelectorAll('.ai-slideshow-slide-{{ ai_gen_id }}');
        this.dots = this.querySelectorAll('.ai-slideshow-dot-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-slideshow-nav-{{ ai_gen_id }}.prev');
        this.nextButton = this.querySelector('.ai-slideshow-nav-{{ ai_gen_id }}.next');
        this.textTrack = this.querySelector('.ai-slideshow-text-track-{{ ai_gen_id }}');
        
        this.autoplay = this.dataset.autoplay === 'true';
        this.autoplaySpeed = parseInt(this.dataset.autoplaySpeed) * 1000;
        this.scrollSpeed = parseFloat(this.dataset.scrollSpeed);

        this.setupEventListeners();
        this.startScrollingText();
        
        if (this.autoplay && this.slides.length > 1) {
          this.startAutoplay();
        }
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.previousSlide());
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.nextSlide());
        }

        this.dots.forEach((dot, index) => {
          dot.addEventListener('click', () => this.goToSlide(index));
        });

        this.addEventListener('mouseenter', () => {
          if (this.autoplay) {
            this.stopAutoplay();
          }
        });

        this.addEventListener('mouseleave', () => {
          if (this.autoplay && this.slides.length > 1) {
            this.startAutoplay();
          }
        });
      }

      goToSlide(index) {
        this.slides.forEach((slide, i) => {
          if (i === index) {
            slide.classList.add('active');
          } else {
            slide.classList.remove('active');
          }
        });

        this.dots.forEach((dot, i) => {
          if (i === index) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });

        this.currentSlide = index;
      }

      nextSlide() {
        const nextIndex = (this.currentSlide + 1) % this.slides.length;
        this.goToSlide(nextIndex);
      }

      previousSlide() {
        const prevIndex = (this.currentSlide - 1 + this.slides.length) % this.slides.length;
        this.goToSlide(prevIndex);
      }

      startAutoplay() {
        this.stopAutoplay();
        this.autoplayInterval = setInterval(() => {
          this.nextSlide();
        }, this.autoplaySpeed);
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }

      startScrollingText() {
        if (!this.textTrack) return;

        const scroll = () => {
          this.scrollPosition -= this.scrollSpeed;
          
          const trackWidth = this.textTrack.scrollWidth / 2;
          
          if (Math.abs(this.scrollPosition) >= trackWidth) {
            this.scrollPosition = 0;
          }
          
          this.textTrack.style.transform = `translateX(${this.scrollPosition}px)`;
          
          this.scrollAnimationFrame = requestAnimationFrame(scroll);
        };

        scroll();
      }

      disconnectedCallback() {
        this.stopAutoplay();
        if (this.scrollAnimationFrame) {
          cancelAnimationFrame(this.scrollAnimationFrame);
        }
      }
    }

    customElements.define('image-slideshow-{{ ai_gen_id }}', ImageSlideshow{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Image slideshow",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image 1"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image 2"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Image 3"
    },
    {
      "type": "image_picker",
      "id": "image_4",
      "label": "Image 4"
    },
    {
      "type": "image_picker",
      "id": "image_5",
      "label": "Image 5"
    },
    {
      "type": "header",
      "content": "Slideshow settings"
    },
    {
      "type": "range",
      "id": "slideshow_height",
      "min": 200,
      "max": 800,
      "step": 50,
      "unit": "px",
      "label": "Height",
      "default": 500
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay slides",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "Autoplay speed",
      "default": 5
    },
    {
      "type": "range",
      "id": "transition_speed",
      "min": 0.5,
      "max": 2,
      "step": 0.5,
      "unit": "s",
      "label": "Transition speed",
      "default": 1
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "checkbox",
      "id": "show_navigation",
      "label": "Show navigation arrows",
      "default": true
    },
    {
      "type": "range",
      "id": "nav_button_size",
      "min": 30,
      "max": 60,
      "step": 5,
      "unit": "px",
      "label": "Button size",
      "default": 40
    },
    {
      "type": "range",
      "id": "nav_button_offset",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Button offset",
      "default": 20
    },
    {
      "type": "range",
      "id": "nav_button_opacity",
      "min": 30,
      "max": 100,
      "step": 10,
      "unit": "%",
      "label": "Button opacity",
      "default": 70
    },
    {
      "type": "color",
      "id": "nav_button_color",
      "label": "Button background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "nav_button_icon_color",
      "label": "Button icon",
      "default": "#000000"
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show dots",
      "default": true
    },
    {
      "type": "color",
      "id": "dot_color",
      "label": "Dot color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Scrolling text"
    },
    {
      "type": "text",
