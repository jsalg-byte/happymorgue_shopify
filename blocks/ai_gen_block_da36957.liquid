{% doc %}
  @prompt
    Just make a button that says upcoming events that links to our event tabs with a movie poster style flier spot on the right that will show that event. Make it very minimal and clean 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-event-block-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-event-container-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.spacing }}px;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-event-button-wrapper-{{ ai_gen_id }} {
    flex-shrink: 0;
  }

  .ai-event-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border: {{ block.settings.button_border_thickness }}px solid {{ block.settings.button_border_color }};
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 500;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    transition: all 0.2s ease;
  }

  .ai-event-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  .ai-event-poster-{{ ai_gen_id }} {
    flex: 1;
    max-width: {{ block.settings.poster_max_width }}px;
    aspect-ratio: {{ block.settings.poster_aspect_ratio }};
    overflow: hidden;
    border: {{ block.settings.poster_border_thickness }}px solid {{ block.settings.poster_border_color }};
  }

  .ai-event-poster-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-event-poster-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-event-poster-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-event-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 8px 16px;
    background-color: rgba(255, 255, 255, 0.9);
    font-size: 12px;
    color: #666;
    text-align: center;
    pointer-events: none;
    white-space: nowrap;
  }

  @media screen and (max-width: 749px) {
    .ai-event-container-{{ ai_gen_id }} {
      flex-direction: column;
      gap: {{ block.settings.spacing | times: 0.75 }}px;
    }

    .ai-event-button-wrapper-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-event-button-{{ ai_gen_id }} {
      width: 100%;
      text-align: center;
    }

    .ai-event-poster-{{ ai_gen_id }} {
      max-width: 100%;
    }
  }
{% endstyle %}

<event-block-{{ ai_gen_id }} class="ai-event-block-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-event-container-{{ ai_gen_id }}">
    <div class="ai-event-button-wrapper-{{ ai_gen_id }}">
      <a href="{{ block.settings.button_link }}" class="ai-event-button-{{ ai_gen_id }}">
        {{ block.settings.button_text }}
      </a>
    </div>

    <div class="ai-event-poster-{{ ai_gen_id }}">
      {% if block.settings.poster_image %}
        <img
          src="{{ block.settings.poster_image | image_url: width: 800 }}"
          alt="{{ block.settings.poster_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.poster_image.width }}"
          height="{{ block.settings.poster_image.height }}"
        >
      {% else %}
        <div class="ai-event-poster-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-event-empty-state-{{ ai_gen_id }}">
            Add event poster image
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</event-block-{{ ai_gen_id }}>

<script>
  (function() {
    class EventBlock{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }
    customElements.define('event-block-{{ ai_gen_id }}', EventBlock{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Event button with poster",
  "settings": [
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Upcoming Events"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "button_font_size",
      "label": "Font size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "button_padding_vertical",
      "label": "Vertical padding",
      "min": 8,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "button_padding_horizontal",
      "label": "Horizontal padding",
      "min": 16,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_background",
      "label": "Hover background color",
      "default": "#d80000"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Hover text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "button_border_thickness",
      "label": "Border thickness",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "color",
      "id": "button_border_color",
      "label": "Border color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_hover_border_color",
      "label": "Hover border color",
      "default": "#d80000"
    },
    {
      "type": "header",
      "content": "Poster"
    },
    {
      "type": "image_picker",
      "id": "poster_image",
      "label": "Poster image"
    },
    {
      "type": "select",
      "id": "poster_aspect_ratio",
      "label": "Aspect ratio",
      "options": [
        {
          "value": "2/3",
          "label": "Movie poster (2:3)"
        },
        {
          "value": "3/4",
          "label": "Portrait (3:4)"
        },
        {
          "value": "1/1",
          "label": "Square (1:1)"
        },
        {
          "value": "4/3",
          "label": "Landscape (4:3)"
        }
      ],
      "default": "2/3"
    },
    {
      "type": "range",
      "id": "poster_max_width",
      "label": "Maximum width",
      "min": 200,
      "max": 600,
      "step": 20,
      "unit": "px",
      "default": 300
    },
    {
      "type": "range",
      "id": "poster_border_thickness",
      "label": "Border thickness",
      "min": 0,
      "max": 8,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "color",
      "id": "poster_border_color",
      "label": "Border color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "spacing",
      "label": "Space between elements",
      "min": 16,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Container padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Event button with poster"
    }
  ],
  "tag": null
}
{% endschema %}