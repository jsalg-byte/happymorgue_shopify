{% doc %}
  @prompt
    Make a slide show to showcase our photo shoots. Allow us to add unlimited pics. Make it very minimal. Make the images stay the same size and make the transition a channel flip , Keep everything the same but make the transition more like a static tv channel flip. Like channel surfing thru the slideshow , Make it look more like a tv shutting on and off between pictures. Make it a smooth transition , Actually make the pictures burn and dissolve into the next slide. No fire just the results of it being burnt and dissolved, Ok just make it a normal slideshow., No like make the picture slide into the next slide. Like the pictures slide in 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-slideshow-{{ ai_gen_id }} {
    display: block;
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    overflow: hidden;
    background-color: {{ block.settings.background_color }};
  }

  .ai-slideshow-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: {{ block.settings.aspect_ratio }};
    overflow: hidden;
  }

  .ai-slideshow-slide-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    transform: translateX(100%);
    transition: transform {{ block.settings.transition_speed }}s ease-in-out;
  }

  .ai-slideshow-slide-{{ ai_gen_id }}.active {
    transform: translateX(0);
    z-index: 2;
  }

  .ai-slideshow-slide-{{ ai_gen_id }}.previous {
    transform: translateX(-100%);
    z-index: 1;
  }

  .ai-slideshow-slide-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-slideshow-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-slideshow-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
  }

  .ai-slideshow-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-slideshow-controls-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
    z-index: 10;
  }

  .ai-slideshow-dot-{{ ai_gen_id }} {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    opacity: 0.5;
    border: none;
    padding: 0;
    cursor: pointer;
    transition: opacity 0.3s ease;
  }

  .ai-slideshow-dot-{{ ai_gen_id }}.active {
    opacity: 1;
  }

  .ai-slideshow-dot-{{ ai_gen_id }}:hover {
    opacity: 0.8;
  }

  @media screen and (max-width: 749px) {
    .ai-slideshow-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<photo-slideshow-{{ ai_gen_id }} class="ai-slideshow-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-slideshow-container-{{ ai_gen_id }}">
    {% liquid
      assign images = ''
      assign image_count = 0
      
      for i in (1..20)
        assign image_key = 'image_' | append: i
        assign current_image = block.settings[image_key]
        if current_image != blank
          assign image_count = image_count | plus: 1
          if images == ''
            assign images = image_key
          else
            assign images = images | append: ',' | append: image_key
          endif
        endif
      endfor
    %}

    {% if image_count > 0 %}
      {% assign image_keys = images | split: ',' %}
      {% for image_key in image_keys %}
        {% assign current_image = block.settings[image_key] %}
        <div class="ai-slideshow-slide-{{ ai_gen_id }}" data-slide-index="{{ forloop.index0 }}">
          <img
            src="{{ current_image | image_url: width: 2000 }}"
            alt="{{ current_image.alt | escape }}"
            loading="lazy"
            width="{{ current_image.width }}"
            height="{{ current_image.height }}"
          >
        </div>
      {% endfor %}
    {% else %}
      <div class="ai-slideshow-placeholder-{{ ai_gen_id }}">
        {{ 'image' | placeholder_svg_tag }}
        <div class="ai-slideshow-empty-state-{{ ai_gen_id }}">
          Add images to your slideshow
        </div>
      </div>
    {% endif %}
  </div>

  {% if image_count > 1 %}
    <div class="ai-slideshow-controls-{{ ai_gen_id }}">
      {% for i in (1..image_count) %}
        <button
          class="ai-slideshow-dot-{{ ai_gen_id }}"
          data-slide-index="{{ forloop.index0 }}"
          aria-label="Go to slide {{ forloop.index }}"
        ></button>
      {% endfor %}
    </div>
  {% endif %}
</photo-slideshow-{{ ai_gen_id }}>

<script>
  (function() {
    class PhotoSlideshow{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.slides = [];
        this.dots = [];
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.slides = Array.from(this.querySelectorAll('.ai-slideshow-slide-{{ ai_gen_id }}'));
        this.dots = Array.from(this.querySelectorAll('.ai-slideshow-dot-{{ ai_gen_id }}'));
        
        if (this.slides.length === 0) return;

        this.slides[0].classList.add('active');
        if (this.dots.length > 0) {
          this.dots[0].classList.add('active');
        }

        this.setupEventListeners();
        this.startAutoplay();
      }

      setupEventListeners() {
        this.dots.forEach((dot, index) => {
          dot.addEventListener('click', () => {
            this.goToSlide(index);
          });
        });
      }

      goToSlide(index) {
        if (index === this.currentIndex) return;

        this.slides[this.currentIndex].classList.remove('active');
        this.slides[this.currentIndex].classList.add('previous');
        this.dots[this.currentIndex].classList.remove('active');

        this.currentIndex = index;

        this.slides.forEach((slide, i) => {
          if (i !== this.currentIndex) {
            slide.classList.remove('active');
            if (i < this.currentIndex) {
              slide.classList.add('previous');
            } else {
              slide.classList.remove('previous');
            }
          }
        });

        this.slides[this.currentIndex].classList.remove('previous');
        this.slides[this.currentIndex].classList.add('active');
        this.dots[this.currentIndex].classList.add('active');

        this.resetAutoplay();
      }

      nextSlide() {
        const nextIndex = (this.currentIndex + 1) % this.slides.length;
        this.goToSlide(nextIndex);
      }

      startAutoplay() {
        if (this.slides.length <= 1) return;
        
        const autoplaySpeed = {{ block.settings.autoplay_speed | times: 1000 }};
        this.autoplayInterval = setInterval(() => {
          this.nextSlide();
        }, autoplaySpeed);
      }

      resetAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.startAutoplay();
        }
      }

      disconnectedCallback() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
        }
      }
    }

    customElements.define('photo-slideshow-{{ ai_gen_id }}', PhotoSlideshow{{ ai_gen_id }});
  })();
</script>

