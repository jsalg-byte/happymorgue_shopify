{% doc %}
  @prompt
    Make a slide show to showcase our photo shoots. Allow us to add unlimited pics. Make it very minimal 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-slideshow-{{ ai_gen_id }} {
    display: block;
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    background-color: {{ block.settings.background_color }};
  }

  .ai-slideshow-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .ai-slideshow-track-{{ ai_gen_id }} {
    display: flex;
    width: 100%;
  }

  .ai-slideshow-slide-{{ ai_gen_id }} {
    min-width: 100%;
    opacity: 0;
    visibility: hidden;
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
  }

  .ai-slideshow-slide-{{ ai_gen_id }}.active {
    opacity: 1;
    visibility: visible;
    position: relative;
  }

  .ai-slideshow-slide-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .ai-slideshow-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: {{ block.settings.aspect_ratio }};
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-slideshow-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
  }

  .ai-slideshow-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-slideshow-nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: {{ block.settings.nav_color }};
    border: none;
    width: {{ block.settings.nav_size }}px;
    height: {{ block.settings.nav_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 2;
    opacity: {{ block.settings.nav_opacity }};
  }

  .ai-slideshow-nav-{{ ai_gen_id }}:hover {
    opacity: 1;
  }

  .ai-slideshow-nav-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.nav_size }}px * 0.5);
    height: calc({{ block.settings.nav_size }}px * 0.5);
    stroke: {{ block.settings.nav_icon_color }};
  }

  .ai-slideshow-nav-prev-{{ ai_gen_id }} {
    left: {{ block.settings.nav_offset }}px;
  }

  .ai-slideshow-nav-next-{{ ai_gen_id }} {
    right: {{ block.settings.nav_offset }}px;
  }

  .ai-slideshow-dots-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: {{ block.settings.dot_spacing }}px;
    padding: {{ block.settings.dot_padding }}px 0;
  }

  .ai-slideshow-dot-{{ ai_gen_id }} {
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    padding: 0;
    opacity: 0.4;
  }

  .ai-slideshow-dot-{{ ai_gen_id }}.active {
    opacity: 1;
  }

  @media screen and (max-width: 749px) {
    .ai-slideshow-nav-{{ ai_gen_id }} {
      width: calc({{ block.settings.nav_size }}px * 0.8);
      height: calc({{ block.settings.nav_size }}px * 0.8);
    }

    .ai-slideshow-nav-prev-{{ ai_gen_id }} {
      left: calc({{ block.settings.nav_offset }}px * 0.5);
    }

    .ai-slideshow-nav-next-{{ ai_gen_id }} {
      right: calc({{ block.settings.nav_offset }}px * 0.5);
    }
  }
{% endstyle %}

<photo-slideshow-{{ ai_gen_id }} class="ai-slideshow-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-slideshow-container-{{ ai_gen_id }}">
    <div class="ai-slideshow-track-{{ ai_gen_id }}">
      {% liquid
        assign has_images = false
        for i in (1..20)
          assign image_key = 'image_' | append: i
          if block.settings[image_key] != blank
            assign has_images = true
            break
          endif
        endfor
      %}

      {% if has_images %}
        {% for i in (1..20) %}
          {% liquid
            assign image_key = 'image_' | append: i
            assign image = block.settings[image_key]
          %}
          {% if image != blank %}
            <div class="ai-slideshow-slide-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}" data-slide-index="{{ forloop.index0 }}">
              <img
                src="{{ image | image_url: width: 2000 }}"
                alt="{{ image.alt | escape }}"
                loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                width="{{ image.width }}"
                height="{{ image.height }}"
              >
            </div>
          {% endif %}
        {% endfor %}
      {% else %}
        <div class="ai-slideshow-slide-{{ ai_gen_id }} active">
          <div class="ai-slideshow-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="ai-slideshow-empty-state-{{ ai_gen_id }}">
              Add images to create your slideshow
            </div>
          </div>
        </div>
      {% endif %}
    </div>

    {% if has_images and block.settings.show_arrows %}
      <button
        class="ai-slideshow-nav-{{ ai_gen_id }} ai-slideshow-nav-prev-{{ ai_gen_id }}"
        aria-label="Previous slide"
        data-nav="prev"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>
      <button
        class="ai-slideshow-nav-{{ ai_gen_id }} ai-slideshow-nav-next-{{ ai_gen_id }}"
        aria-label="Next slide"
        data-nav="next"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    {% endif %}
  </div>

  {% if has_images and block.settings.show_dots %}
    <div class="ai-slideshow-dots-{{ ai_gen_id }}">
      {% for i in (1..20) %}
        {% liquid
          assign image_key = 'image_' | append: i
          assign image = block.settings[image_key]
        %}
        {% if image != blank %}
          <button
            class="ai-slideshow-dot-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
            aria-label="Go to slide {{ forloop.index }}"
            data-dot-index="{{ forloop.index0 }}"
          ></button>
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}
</photo-slideshow-{{ ai_gen_id }}>

<script>
  (function() {
    class PhotoSlideshow{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.slides = [];
        this.dots = [];
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.slides = Array.from(this.querySelectorAll('.ai-slideshow-slide-{{ ai_gen_id }}'));
        this.dots = Array.from(this.querySelectorAll('.ai-slideshow-dot-{{ ai_gen_id }}'));
        
        if (this.slides.length <= 1) return;

        this.setupNavigation();
        this.setupDots();
        
        {% if block.settings.autoplay %}
          this.startAutoplay();
          this.addEventListener('mouseenter', () => this.stopAutoplay());
          this.addEventListener('mouseleave', () => this.startAutoplay());
        {% endif %}
      }

      setupNavigation() {
        const prevBtn = this.querySelector('[data-nav="prev"]');
        const nextBtn = this.querySelector('[data-nav="next"]');

        if (prevBtn) {
          prevBtn.addEventListener('click', () => this.goToSlide(this.currentIndex - 1));
        }
        if (nextBtn) {
          nextBtn.addEventListener('click', () => this.goToSlide(this.currentIndex + 1));
        }
      }

      setupDots() {
        this.dots.forEach((dot, index) => {
          dot.addEventListener('click', () => this.goToSlide(index));
        });
      }

      goToSlide(index) {
        if (index < 0) {
          index = this.slides.length - 1;
        } else if (index >= this.slides.length) {
          index = 0;
        }

        this.slides[this.currentIndex].classList.remove('active');
        if (this.dots[this.currentIndex]) {
          this.dots[this.currentIndex].classList.remove('active');
        }

        this.currentIndex = index;

        this.slides[this.currentIndex].classList.add('active');
        if (this.dots[this.currentIndex]) {
          this.dots[this.currentIndex].classList.add('active');
        }
      }

      startAutoplay() {
        this.autoplayInterval = setInterval(() => {
          this.goToSlide(this.currentIndex + 1);
        }, {{ block.settings.autoplay_speed | times: 1000 }});
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }
    }

    customElements.define('photo-slideshow-{{ ai_gen_id }}', PhotoSlideshow{{ ai_gen_id }});
  })();
</script>

