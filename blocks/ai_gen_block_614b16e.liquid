{% doc %}
  @prompt
    Create a classic snake game where players control a snake that grows longer each time it eats food. Include arrow key controls for desktop and swipe controls for mobile, score tracking based on food eaten, game over when the snake hits walls or itself, and restart functionality. Style it with a clean grid layout and make it visually appealing with smooth animations.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-snake-game-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 40px 20px;
    background-color: {{ block.settings.background_color }};
    min-height: 600px;
  }

  .ai-snake-game-container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    max-width: 100%;
  }

  .ai-snake-game-header-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    max-width: {{ block.settings.grid_size | times: block.settings.cell_size }}px;
    padding: 15px 20px;
    background-color: {{ block.settings.header_bg_color }};
    border-radius: {{ block.settings.border_radius }}px;
    color: {{ block.settings.text_color }};
  }

  .ai-snake-game-score-{{ ai_gen_id }} {
    font-size: 20px;
    font-weight: 600;
  }

  .ai-snake-game-high-score-{{ ai_gen_id }} {
    font-size: 16px;
    opacity: 0.8;
  }

  .ai-snake-game-canvas-wrapper-{{ ai_gen_id }} {
    position: relative;
    border: {{ block.settings.border_thickness }}px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
  }

  .ai-snake-game-canvas-{{ ai_gen_id }} {
    display: block;
    background-color: {{ block.settings.grid_bg_color }};
  }

  .ai-snake-game-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.8);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 20px;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  .ai-snake-game-overlay-{{ ai_gen_id }}.active {
    opacity: 1;
    visibility: visible;
  }

  .ai-snake-game-overlay-title-{{ ai_gen_id }} {
    font-size: 32px;
    font-weight: 700;
    color: #ffffff;
    text-align: center;
  }

  .ai-snake-game-overlay-message-{{ ai_gen_id }} {
    font-size: 18px;
    color: #ffffff;
    text-align: center;
    opacity: 0.9;
  }

  .ai-snake-game-button-{{ ai_gen_id }} {
    padding: 12px 32px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: transform 0.2s ease, background-color 0.2s ease;
  }

  .ai-snake-game-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
    transform: translateY(-2px);
  }

  .ai-snake-game-controls-{{ ai_gen_id }} {
    display: none;
    grid-template-columns: repeat(3, 60px);
    grid-template-rows: repeat(2, 60px);
    gap: 10px;
    margin-top: 20px;
  }

  .ai-snake-game-control-btn-{{ ai_gen_id }} {
    background-color: {{ block.settings.control_button_color }};
    color: {{ block.settings.control_button_text_color }};
    border: none;
    border-radius: 8px;
    font-size: 24px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.2s ease, transform 0.1s ease;
  }

  .ai-snake-game-control-btn-{{ ai_gen_id }}:active {
    transform: scale(0.95);
  }

  .ai-snake-game-control-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.control_button_hover_color }};
  }

  .ai-snake-game-control-up-{{ ai_gen_id }} {
    grid-column: 2;
    grid-row: 1;
  }

  .ai-snake-game-control-left-{{ ai_gen_id }} {
    grid-column: 1;
    grid-row: 2;
  }

  .ai-snake-game-control-down-{{ ai_gen_id }} {
    grid-column: 2;
    grid-row: 2;
  }

  .ai-snake-game-control-right-{{ ai_gen_id }} {
    grid-column: 3;
    grid-row: 2;
  }

  .ai-snake-game-instructions-{{ ai_gen_id }} {
    text-align: center;
    color: {{ block.settings.text_color }};
    font-size: 14px;
    opacity: 0.7;
    max-width: {{ block.settings.grid_size | times: block.settings.cell_size }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-snake-game-{{ ai_gen_id }} {
      padding: 20px 10px;
    }

    .ai-snake-game-controls-{{ ai_gen_id }} {
      display: grid;
    }

    .ai-snake-game-canvas-{{ ai_gen_id }} {
      max-width: 100%;
      height: auto;
    }

    .ai-snake-game-overlay-title-{{ ai_gen_id }} {
      font-size: 24px;
    }

    .ai-snake-game-overlay-message-{{ ai_gen_id }} {
      font-size: 16px;
    }
  }
{% endstyle %}

<snake-game-{{ ai_gen_id }} class="ai-snake-game-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-snake-game-container-{{ ai_gen_id }}">
    <div class="ai-snake-game-header-{{ ai_gen_id }}">
      <div class="ai-snake-game-score-{{ ai_gen_id }}">
        Score: <span data-score>0</span>
      </div>
      <div class="ai-snake-game-high-score-{{ ai_gen_id }}">
        High Score: <span data-high-score>0</span>
      </div>
    </div>

    <div class="ai-snake-game-canvas-wrapper-{{ ai_gen_id }}">
      <canvas
        class="ai-snake-game-canvas-{{ ai_gen_id }}"
        width="{{ block.settings.grid_size | times: block.settings.cell_size }}"
        height="{{ block.settings.grid_size | times: block.settings.cell_size }}"
        data-canvas
      ></canvas>

      <div class="ai-snake-game-overlay-{{ ai_gen_id }}" data-overlay>
        <div class="ai-snake-game-overlay-title-{{ ai_gen_id }}" data-overlay-title>
          {{ block.settings.start_title }}
        </div>
        <div class="ai-snake-game-overlay-message-{{ ai_gen_id }}" data-overlay-message>
          {{ block.settings.start_message }}
        </div>
        <button class="ai-snake-game-button-{{ ai_gen_id }}" data-start-button>
          {{ block.settings.start_button_text }}
        </button>
      </div>
    </div>

    <div class="ai-snake-game-controls-{{ ai_gen_id }}">
      <button class="ai-snake-game-control-btn-{{ ai_gen_id }} ai-snake-game-control-up-{{ ai_gen_id }}" data-control="up" aria-label="Move up">
        ▲
      </button>
      <button class="ai-snake-game-control-btn-{{ ai_gen_id }} ai-snake-game-control-left-{{ ai_gen_id }}" data-control="left" aria-label="Move left">
        ◀
      </button>
      <button class="ai-snake-game-control-btn-{{ ai_gen_id }} ai-snake-game-control-down-{{ ai_gen_id }}" data-control="down" aria-label="Move down">
        ▼
      </button>
      <button class="ai-snake-game-control-btn-{{ ai_gen_id }} ai-snake-game-control-right-{{ ai_gen_id }}" data-control="right" aria-label="Move right">
        ▶
      </button>
    </div>

    <div class="ai-snake-game-instructions-{{ ai_gen_id }}">
      {{ block.settings.instructions }}
    </div>
  </div>
</snake-game-{{ ai_gen_id }}>

<script>
  (function() {
    class SnakeGame{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.canvas = this.querySelector('[data-canvas]');
        this.ctx = this.canvas.getContext('2d');
        this.overlay = this.querySelector('[data-overlay]');
        this.overlayTitle = this.querySelector('[data-overlay-title]');
        this.overlayMessage = this.querySelector('[data-overlay-message]');
        this.startButton = this.querySelector('[data-start-button]');
        this.scoreDisplay = this.querySelector('[data-score]');
        this.highScoreDisplay = this.querySelector('[data-high-score]');
        this.controlButtons = this.querySelectorAll('[data-control]');

        this.gridSize = {{ block.settings.grid_size }};
        this.cellSize = {{ block.settings.cell_size }};
        this.gameSpeed = {{ block.settings.game_speed }};
        this.snakeColor = '{{ block.settings.snake_color }}';
        this.foodColor = '{{ block.settings.food_color }}';
        this.gridLineColor = '{{ block.settings.grid_line_color }}';

        this.snake = [];
        this.direction = { x: 1, y: 0 };
        this.nextDirection = { x: 1, y: 0 };
        this.food = { x: 0, y: 0 };
        this.score = 0;
        this.highScore = this.loadHighScore();
        this.gameLoop = null;
        this.isGameOver = false;
        this.isGameStarted = false;

        this.touchStartX = 0;
        this.touchStartY = 0;
      }

      connectedCallback() {
        this.highScoreDisplay.textContent = this.highScore;
        this.setupEventListeners();
        this.showOverlay('{{ block.settings.start_title }}', '{{ block.settings.start_message }}', '{{ block.settings.start_button_text }}');
        this.drawGrid();
      }

      setupEventListeners() {
        this.startButton.addEventListener('click', () => this.startGame());
        
        document.addEventListener('keydown', (e) => {
          if (!this.isGameStarted) return;
          
          switch(e.key) {
            case 'ArrowUp':
              e.preventDefault();
              if (this.direction.y === 0) {
                this.nextDirection = { x: 0, y: -1 };
              }
              break;
            case 'ArrowDown':
              e.preventDefault();
              if (this.direction.y === 0) {
                this.nextDirection = { x: 0, y: 1 };
              }
              break;
            case 'ArrowLeft':
              e.preventDefault();
              if (this.direction.x === 0) {
                this.nextDirection = { x: -1, y: 0 };
              }
              break;
            case 'ArrowRight':
              e.preventDefault();
              if (this.direction.x === 0) {
                this.nextDirection = { x: 1, y: 0 };
              }
              break;
          }
        });

        this.controlButtons.forEach(button => {
          button.addEventListener('click', () => {
            if (!this.isGameStarted) return;
            
            const control = button.getAttribute('data-control');
            switch(control) {
              case 'up':
                if (this.direction.y === 0) {
                  this.nextDirection = { x: 0, y: -1 };
                }
                break;
              case 'down':
                if (this.direction.y === 0) {
                  this.nextDirection = { x: 0, y: 1 };
                }
                break;
              case 'left':
                if (this.direction.x === 0) {
                  this.nextDirection = { x: -1, y: 0 };
                }
                break;
              case 'right':
                if (this.direction.x === 0) {
                  this.nextDirection = { x: 1, y: 0 };
                }
                break;
            }
          });
        });

        this.canvas.addEventListener('touchstart', (e) => {
          if (!this.isGameStarted) return;
          this.touchStartX = e.touches[0].clientX;
          this.touchStartY = e.touches[0].clientY;
        });

        this.canvas.addEventListener('touchend', (e) => {
          if (!this.isGameStarted) return;
          
          const touchEndX = e.changedTouches[0].clientX;
          const touchEndY = e.changedTouches[0].clientY;
          
          const deltaX = touchEndX - this.touchStartX;
          const deltaY = touchEndY - this.touchStartY;
          
          if (Math.abs(deltaX) > Math.abs(deltaY)) {
            if (deltaX > 0 && this.direction.x === 0) {
              this.nextDirection = { x: 1, y: 0 };
            } else if (deltaX < 0 && this.direction.x === 0) {
              this.nextDirection = { x: -1, y: 0 };
            }
          } else {
            if (deltaY > 0 && this.direction.y === 0) {
              this.nextDirection = { x: 0, y: 1 };
            } else if (deltaY < 0 && this.direction.y === 0) {
              this.nextDirection = { x: 0, y: -1 };
            }
          }
        });
      }

      startGame() {
        this.hideOverlay();
        this.isGameStarted = true;
        this.isGameOver = false;
        this.score = 0;
        this.direction = { x: 1, y: 0 };
        this.nextDirection = { x: 1, y: 0 };
        this.scoreDisplay.textContent = this.score;
        
        const centerPos = Math.floor(this.gridSize / 2);
        this.snake = [
          { x: centerPos, y: centerPos },
          { x: centerPos - 1, y: centerPos },
          { x: centerPos - 2, y: centerPos }
        ];
        
        this.spawnFood();
        
        if (this.gameLoop) {
          clearInterval(this.gameLoop);
        }
        
        this.gameLoop = setInterval(() => this.update(), this.gameSpeed);
      }

      update() {
        this.direction = this.nextDirection;
        
        const head = { 
          x: this.snake[0].x + this.direction.x, 
          y: this.snake[0].y + this.direction.y 
        };

        if (head.x < 0 || head.x >= this.gridSize || 
            head.y < 0 || head.y >= this.gridSize ||
            this.snake.some(segment => segment.x === head.x && segment.y === head.y)) {
          this.endGame();
          return;
        }

        this.snake.unshift(head);

        if (head.x === this.food.x && head.y === this.food.y) {
          this.score++;
          this.scoreDisplay.textContent = this.score;
          this.spawnFood();
          
          if (this.score > this.highScore) {
            this.highScore = this.score;
            this.highScoreDisplay.textContent = this.highScore;
            this.saveHighScore();
          }
        } else {
          this.snake.pop();
        }

        this.draw();
      }

      draw() {
        this.ctx.clearRect(0, 0, this.canvas.width, this.canvas.height);
        this.drawGrid();
        
        this.ctx.fillStyle = this.snakeColor;
        this.snake.forEach((segment, index) => {
          this.ctx.fillRect(
            segment.x * this.cellSize,
            segment.y * this.cellSize,
            this.cellSize - 1,
            this.cellSize - 1
          );
        });

        this.ctx.fillStyle = this.foodColor;
        this.ctx.beginPath();
        this.ctx.arc(
          this.food.x * this.cellSize + this.cellSize / 2,
          this.food.y * this.cellSize + this.cellSize / 2,
          this.cellSize / 2 - 2,
          0,
          Math.PI * 2
        );
        this.ctx.fill();
      }

      drawGrid() {
        this.ctx.strokeStyle = this.gridLineColor;
        this.ctx.lineWidth = 0.5;
        
        for (let i = 0; i <= this.gridSize; i++) {
          this.ctx.beginPath();
          this.ctx.moveTo(i * this.cellSize, 0);
          this.ctx.lineTo(i * this.cellSize, this.canvas.height);
          this.ctx.stroke();
          
          this.ctx.beginPath();
          this.ctx.moveTo(0, i * this.cellSize);
          this.ctx.lineTo(this.canvas.width, i * this.cellSize);
          this.ctx.stroke();
        }
      }

      spawnFood() {
        let newFood;
        do {
          newFood = {
            x: Math.floor(Math.random() * this.gridSize),
            y: Math.floor(Math.random() * this.gridSize)
          };
        } while (this.snake.some(segment => segment.x === newFood.x && segment.y === newFood.y));
        
        this.food = newFood;
      }

      endGame() {
        this.isGameStarted = false;
        this.isGameOver = true;
        clearInterval(this.gameLoop);
        
        const message = '{{ block.settings.game_over_message }}'.replace('[SCORE]', this.score);
        this.showOverlay('{{ block.settings.game_over_title }}', message, '{{ block.settings.restart_button_text }}');
      }

      showOverlay(title, message, buttonText) {
        this.overlayTitle.textContent = title;
        this.overlayMessage.textContent = message;
        this.startButton.textContent = buttonText;
        this.overlay.classList.add('active');
      }

      hideOverlay() {
        this.overlay.classList.remove('active');
      }

      loadHighScore() {
        const saved = localStorage.getItem('snakeHighScore{{ ai_gen_id }}');
        return saved ? parseInt(saved) : 0;
      }

      saveHighScore() {
        localStorage.setItem('snakeHighScore{{ ai_gen_id }}', this.highScore.toString());
      }

      disconnectedCallback() {
        if (this.gameLoop) {
          clearInterval(this.gameLoop);
        }
      }
    }

    customElements.define('snake-game-{{ ai_gen_id }}', SnakeGame{{ ai_gen_id }});
  })();
</script>

