      "type": "text",
      "id": "badge_label",
      "label": "Badge text",
      "default": "NEW RELEASE"
    },
    {
      "type": "header",
      "content": "Screenshot"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Game screenshot"
    },
    {
