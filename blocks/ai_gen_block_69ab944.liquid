      "default": "ACTUAL GAME FOOTAGE"
    },
    {
      "type": "header",
      "content": "Description"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Enter a world where the pixels bleed and the high scores are written in screams. This isn't just a game—it's a portal to something darker. Are you brave enough to press start?"
