{% doc %}
  @prompt
    a magazine style layout to show case the upcoming game projects were working on with enough slots to showcase images. i have two specific titles i want to display , ok make the first image slot a video slot. and make all the project files just image slots withou it being assigned to a project., ok just delete the video slot , delete image 1 and keep all of them small like the rest of the images you can play with the sizes just dont make them too big, make them not so symmetrical. give it a cool artsy lay out , ok just make image 2 4 5 not so squishe for the images dont look stretched
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-magazine-layout-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-magazine-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-magazine-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: 40px;
  }

  .ai-magazine-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 12px;
    font-weight: 700;
    letter-spacing: -0.5px;
  }

  .ai-magazine-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
  }

  .ai-magazine-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    grid-auto-rows: 200px;
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-magazine-item-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.item_border_radius }}px;
    background-color: {{ block.settings.item_background }};
  }

  .ai-magazine-item-{{ ai_gen_id }}:nth-child(1) {
    grid-column: span 3;
    grid-row: span 2;
  }

  .ai-magazine-item-{{ ai_gen_id }}:nth-child(2) {
    grid-column: span 3;
    grid-row: span 2;
  }

  .ai-magazine-item-{{ ai_gen_id }}:nth-child(3) {
    grid-column: span 2;
    grid-row: span 2;
  }

  .ai-magazine-item-{{ ai_gen_id }}:nth-child(4) {
    grid-column: span 4;
    grid-row: span 2;
  }

  .ai-magazine-item-{{ ai_gen_id }}:nth-child(5) {
    grid-column: span 2;
    grid-row: span 2;
  }

  .ai-magazine-media-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-magazine-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-magazine-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-magazine-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 150px;
    max-height: 150px;
    opacity: 0.3;
  }

  .ai-magazine-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 13px;
    color: #666;
    text-align: center;
    pointer-events: none;
    white-space: nowrap;
  }

  @media screen and (max-width: 989px) {
    .ai-magazine-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(4, 1fr);
      grid-auto-rows: 180px;
    }

    .ai-magazine-item-{{ ai_gen_id }}:nth-child(1) {
      grid-column: span 2;
      grid-row: span 2;
    }

    .ai-magazine-item-{{ ai_gen_id }}:nth-child(2) {
      grid-column: span 2;
      grid-row: span 2;
    }

    .ai-magazine-item-{{ ai_gen_id }}:nth-child(3) {
      grid-column: span 2;
      grid-row: span 2;
    }

    .ai-magazine-item-{{ ai_gen_id }}:nth-child(4) {
      grid-column: span 2;
      grid-row: span 2;
    }

    .ai-magazine-item-{{ ai_gen_id }}:nth-child(5) {
      grid-column: span 4;
      grid-row: span 2;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-magazine-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 150px;
      gap: {{ block.settings.grid_gap | times: 0.75 }}px;
    }

    .ai-magazine-item-{{ ai_gen_id }}:nth-child(1) {
      grid-column: span 2;
      grid-row: span 2;
    }

    .ai-magazine-item-{{ ai_gen_id }}:nth-child(2) {
      grid-column: span 1;
      grid-row: span 2;
    }

    .ai-magazine-item-{{ ai_gen_id }}:nth-child(3) {
      grid-column: span 1;
      grid-row: span 2;
    }

    .ai-magazine-item-{{ ai_gen_id }}:nth-child(4) {
      grid-column: span 2;
      grid-row: span 2;
    }

    .ai-magazine-item-{{ ai_gen_id }}:nth-child(5) {
      grid-column: span 2;
      grid-row: span 2;
    }

    .ai-magazine-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.75 }}px;
    }
  }
{% endstyle %}

<div class="ai-magazine-layout-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-magazine-container-{{ ai_gen_id }}">
    {% if block.settings.section_title != blank or block.settings.section_subtitle != blank %}
      <div class="ai-magazine-header-{{ ai_gen_id }}">
        {% if block.settings.section_title != blank %}
          <h2 class="ai-magazine-title-{{ ai_gen_id }}">{{ block.settings.section_title }}</h2>
        {% endif %}
        {% if block.settings.section_subtitle != blank %}
          <p class="ai-magazine-subtitle-{{ ai_gen_id }}">{{ block.settings.section_subtitle }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-magazine-grid-{{ ai_gen_id }}">
      {% for i in (1..5) %}
        {% liquid
          assign image_key = 'image_' | append: i
          assign project_image = block.settings[image_key]
        %}

        <div class="ai-magazine-item-{{ ai_gen_id }}">
          <div class="ai-magazine-media-wrapper-{{ ai_gen_id }}">
            {% if project_image %}
              <img
                src="{{ project_image | image_url: width: 1000 }}"
                alt="{{ project_image.alt | escape }}"
                loading="lazy"
                width="{{ project_image.width }}"
                height="{{ project_image.height }}"
                class="ai-magazine-image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-magazine-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
                <div class="ai-magazine-empty-state-{{ ai_gen_id }}">
                  Add image {{ i }}
                </div>
              </div>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Game projects showcase",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Section"
    },
    {
      "type": "text",
      "id": "section_title",
      "label": "Section title",
      "default": "Upcoming Projects"
    },
    {
      "type": "text",
      "id": "section_subtitle",
      "label": "Section subtitle",
      "default": "Discover the games we're working on"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 800,
      "max": 1600,
      "step": 100,
      "unit": "px",
      "label": "Maximum width",
      "default": 1200
    },
    {
      "type": "range",
      "id": "section_padding",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Section padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "grid_gap",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Grid gap",
      "default": 20
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image 1"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image 2"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Image 3"
    },
    {
      "type": "image_picker",
      "id": "image_4",
      "label": "Image 4"
    },
    {
      "type": "image_picker",
      "id": "image_5",
      "label": "Image 5"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Section title",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Section subtitle",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "item_background",
      "label": "Item background",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Section title size",
      "default": 40
    },
    {
      "type": "range",
      "id": "subtitle_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Section subtitle size",
      "default": 16
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "item_border_radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Item border radius",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Game projects showcase"
    }
  ]
}
{% endschema %}
