{% doc %}
  @prompt
    Create a retro 8-bit zombie shooter game with a movable player character. The player is a detailed full-body pixel sprite positioned on the left side and can move up and down using arrow keys or swipe on mobile. Highly detailed full-body pixelated zombies with rotting flesh, torn clothes, visible bones, and classic undead features walk from right to left at varying speeds. Player shoots right by clicking or tapping. Make it challenging: zombies spawn frequently, move at different speeds, some zombies take multiple hits to kill, player has only 3 lives shown as pixel hearts. IMPORTANT: Player dies instantly on collision with any zombie and loses a life. Include pixel muzzle flash when shooting, chunky pixel blood splatter when zombies are hit, score counter with retro font, high score tracking, increasing difficulty over time with faster spawn rates, game over screen, restart button, simple clean 2D retro pixel art style, dark horror palette with zombie greens, blood reds, and black background, and smooth retro animations. Keep the aesthetic simple and classic 2D pixel art like NES games., make it more difficult and and make the player have orange shirt. make the sprite a little more detailed, can you make the main player look like a very simple blocky cowboy, make the sprite design even more simple , can you make the player character a girl like lara croft , make the player blonde, can you make it save highscores? and start if off slow and they progressively get faster until its capped out at a fair speed. and occasionally spawn a fat one thats harder to kill, make them faster 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-zombie-game-{{ ai_gen_id }} {
    width: 100%;
    max-width: 800px;
    margin: 0 auto;
    background-color: {{ block.settings.background_color }};
    padding: 20px;
    border-radius: 4px;
    user-select: none;
    -webkit-user-select: none;
    touch-action: none;
  }

  .ai-zombie-game-canvas-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: #000000;
    border: 4px solid {{ block.settings.border_color }};
    image-rendering: pixelated;
    image-rendering: crisp-edges;
    cursor: crosshair;
  }

  .ai-zombie-game-ui-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 16px;
    padding: 12px;
    background-color: {{ block.settings.ui_background }};
    border: 2px solid {{ block.settings.border_color }};
    font-family: 'Courier New', monospace;
    font-weight: bold;
  }

  .ai-zombie-game-score-{{ ai_gen_id }},
  .ai-zombie-game-high-score-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: 18px;
    text-shadow: 2px 2px 0 #000000;
  }

  .ai-zombie-game-lives-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
  }

  .ai-zombie-game-heart-{{ ai_gen_id }} {
    width: 24px;
    height: 24px;
    image-rendering: pixelated;
  }

  .ai-zombie-game-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    background-color: rgba(0, 0, 0, 0.85);
    z-index: 10;
  }

  .ai-zombie-game-overlay-{{ ai_gen_id }}.hidden {
    display: none;
  }

  .ai-zombie-game-title-{{ ai_gen_id }} {
    font-family: 'Courier New', monospace;
    font-size: 48px;
    font-weight: bold;
    color: {{ block.settings.title_color }};
    text-shadow: 4px 4px 0 #000000;
    margin-bottom: 20px;
    text-align: center;
  }

  .ai-zombie-game-message-{{ ai_gen_id }} {
    font-family: 'Courier New', monospace;
    font-size: 24px;
    color: {{ block.settings.text_color }};
    text-shadow: 2px 2px 0 #000000;
    margin-bottom: 30px;
    text-align: center;
  }

  .ai-zombie-game-button-{{ ai_gen_id }} {
    font-family: 'Courier New', monospace;
    font-size: 24px;
    font-weight: bold;
    padding: 16px 40px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: 4px solid {{ block.settings.border_color }};
    cursor: pointer;
    text-shadow: 2px 2px 0 #000000;
    transition: transform 0.1s;
  }

  .ai-zombie-game-button-{{ ai_gen_id }}:hover {
    transform: scale(1.05);
  }

  .ai-zombie-game-button-{{ ai_gen_id }}:active {
    transform: scale(0.95);
  }

  .ai-zombie-game-container-{{ ai_gen_id }} {
    position: relative;
  }

  @media screen and (max-width: 749px) {
    .ai-zombie-game-title-{{ ai_gen_id }} {
      font-size: 32px;
    }

    .ai-zombie-game-message-{{ ai_gen_id }} {
      font-size: 18px;
    }

    .ai-zombie-game-button-{{ ai_gen_id }} {
      font-size: 20px;
      padding: 12px 30px;
    }

    .ai-zombie-game-score-{{ ai_gen_id }},
    .ai-zombie-game-high-score-{{ ai_gen_id }} {
      font-size: 14px;
    }
  }
{% endstyle %}

<zombie-shooter-{{ ai_gen_id }} class="ai-zombie-game-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-zombie-game-container-{{ ai_gen_id }}">
    <canvas class="ai-zombie-game-canvas-{{ ai_gen_id }}" width="800" height="400"></canvas>
    <div class="ai-zombie-game-overlay-{{ ai_gen_id }}">
      <div class="ai-zombie-game-title-{{ ai_gen_id }}">ZOMBIE SHOOTER</div>
      <div class="ai-zombie-game-message-{{ ai_gen_id }}">Click to Start</div>
      <button class="ai-zombie-game-button-{{ ai_gen_id }}">START GAME</button>
    </div>
  </div>
  <div class="ai-zombie-game-ui-{{ ai_gen_id }}">
    <div class="ai-zombie-game-score-{{ ai_gen_id }}">SCORE: <span class="score-value">0</span></div>
    <div class="ai-zombie-game-lives-{{ ai_gen_id }}"></div>
    <div class="ai-zombie-game-high-score-{{ ai_gen_id }}">HIGH: <span class="high-score-value">0</span></div>
  </div>
</zombie-shooter-{{ ai_gen_id }}>

<script>
(function() {
  class ZombieShooter{{ ai_gen_id }} extends HTMLElement {
    constructor() {
      super();
      this.canvas = this.querySelector('.ai-zombie-game-canvas-{{ ai_gen_id }}');
      this.ctx = this.canvas.getContext('2d');
      this.overlay = this.querySelector('.ai-zombie-game-overlay-{{ ai_gen_id }}');
      this.startButton = this.querySelector('.ai-zombie-game-button-{{ ai_gen_id }}');
      this.scoreElement = this.querySelector('.score-value');
      this.highScoreElement = this.querySelector('.high-score-value');
      this.livesContainer = this.querySelector('.ai-zombie-game-lives-{{ ai_gen_id }}');
      
      this.gameState = 'menu';
      this.score = 0;
      this.highScore = parseInt(localStorage.getItem('zombieHighScore{{ ai_gen_id }}')) || 0;
      this.lives = 3;
      this.player = { x: 80, y: 200, width: 32, height: 48, speed: 4.5 };
      this.bullets = [];
      this.zombies = [];
      this.particles = [];
      this.keys = {};
      this.lastSpawnTime = 0;
      this.spawnInterval = 2000;
      this.baseSpeed = 1.5;
      this.maxSpeed = 5.5;
      this.touchStartY = 0;
      this.isMobile = 'ontouchstart' in window;
      
      this.init();
    }

    init() {
      this.updateHighScore();
      this.updateLives();
      this.startButton.addEventListener('click', () => this.startGame());
      
      document.addEventListener('keydown', (e) => {
        this.keys[e.key] = true;
        if (this.gameState === 'playing' && e.key === ' ') {
          e.preventDefault();
          this.shoot();
        }
      });
      
      document.addEventListener('keyup', (e) => {
        this.keys[e.key] = false;
      });
      
      this.canvas.addEventListener('click', () => {
        if (this.gameState === 'playing') {
          this.shoot();
        }
      });
      
      this.canvas.addEventListener('touchstart', (e) => {
        e.preventDefault();
        this.touchStartY = e.touches[0].clientY;
        if (this.gameState === 'playing') {
          this.shoot();
        }
      });
      
      this.canvas.addEventListener('touchmove', (e) => {
        e.preventDefault();
        if (this.gameState === 'playing') {
          const touchY = e.touches[0].clientY;
          const deltaY = touchY - this.touchStartY;
          this.player.y += deltaY * 0.5;
          this.player.y = Math.max(0, Math.min(this.canvas.height - this.player.height, this.player.y));
          this.touchStartY = touchY;
        }
      });
    }

    startGame() {
      this.gameState = 'playing';
      this.score = 0;
      this.lives = 3;
      this.baseSpeed = 1.5;
      this.player.y = 200;
      this.bullets = [];
      this.zombies = [];
      this.particles = [];
      this.lastSpawnTime = Date.now();
      this.spawnInterval = 2000;
      this.overlay.classList.add('hidden');
      this.updateScore();
      this.updateLives();
      this.gameLoop();
    }

    gameLoop() {
      if (this.gameState !== 'playing') return;
      
      this.update();
      this.draw();
      requestAnimationFrame(() => this.gameLoop());
    }

    update() {
      if (this.keys['ArrowUp'] || this.keys['w']) {
        this.player.y -= this.player.speed;
      }
      if (this.keys['ArrowDown'] || this.keys['s']) {
        this.player.y += this.player.speed;
      }
      
      this.player.y = Math.max(0, Math.min(this.canvas.height - this.player.height, this.player.y));
      
      this.bullets.forEach((bullet, index) => {
        bullet.x += bullet.speed;
        if (bullet.x > this.canvas.width) {
          this.bullets.splice(index, 1);
        }
      });
      
      const now = Date.now();
      if (now - this.lastSpawnTime > this.spawnInterval) {
        this.spawnZombie();
        this.lastSpawnTime = now;
        
        if (this.score > 0 && this.score % 3 === 0) {
          this.baseSpeed = Math.min(this.maxSpeed, this.baseSpeed + 0.25);
          this.spawnInterval = Math.max(600, this.spawnInterval - 100);
        }
      }
      
      this.zombies.forEach((zombie, zIndex) => {
        zombie.x -= zombie.speed;
        zombie.frame = Math.floor(Date.now() / 180) % 2;
        
        if (zombie.x + zombie.width < 0) {
          this.zombies.splice(zIndex, 1);
        }
        
        if (this.checkCollision(this.player, zombie)) {
          this.zombies.splice(zIndex, 1);
          this.loseLife();
        }
        
        this.bullets.forEach((bullet, bIndex) => {
          if (this.checkCollision(bullet, zombie)) {
            this.bullets.splice(bIndex, 1);
            zombie.health--;
            
            this.createBloodSplatter(zombie.x + zombie.width / 2, zombie.y + zombie.height / 2);
            
            if (zombie.health <= 0) {
              this.zombies.splice(zIndex, 1);
              this.score += zombie.isFat ? 3 : 1;
              this.updateScore();
            }
          }
        });
      });
      
      this.particles.forEach((particle, index) => {
        particle.x += particle.vx;
        particle.y += particle.vy;
        particle.life--;
        if (particle.life <= 0) {
          this.particles.splice(index, 1);
        }
      });
    }

    draw() {
      this.ctx.fillStyle = '#000000';
      this.ctx.fillRect(0, 0, this.canvas.width, this.canvas.height);
      
      this.drawPlayer();
      
      this.bullets.forEach(bullet => {
        this.ctx.fillStyle = '#ffff00';
        this.ctx.fillRect(bullet.x, bullet.y, bullet.width, bullet.height);
      });
      
      this.zombies.forEach(zombie => {
        if (zombie.isFat) {
          this.drawFatZombie(zombie);
        } else {
          this.drawZombie(zombie);
        }
      });
      
      this.particles.forEach(particle => {
        this.ctx.fillStyle = particle.color;
        this.ctx.fillRect(particle.x, particle.y, particle.size, particle.size);
      });
    }

    drawPlayer() {
      const x = this.player.x;
      const y = this.player.y;
      
      this.ctx.fillStyle = '#FFD700';
      this.ctx.fillRect(x + 8, y, 16, 12);
      
      this.ctx.fillStyle = '#FFA07A';
      this.ctx.fillRect(x + 10, y + 8, 12, 10);
      
      this.ctx.fillStyle = '#000000';
      this.ctx.fillRect(x + 12, y + 10, 2, 2);
      this.ctx.fillRect(x + 18, y + 10, 2, 2);
      
      this.ctx.fillStyle = '#228B22';
      this.ctx.fillRect(x + 8, y + 18, 16, 14);
      
      this.ctx.fillStyle = '#8B4513';
      this.ctx.fillRect(x + 8, y + 32, 8, 16);
      this.ctx.fillRect(x + 16, y + 32, 8, 16);
      
      this.ctx.fillStyle = '#696969';
      this.ctx.fillRect(x + 24, y + 22, 8, 4);
      
      this.ctx.fillStyle = '#D2691E';
      this.ctx.fillRect(x + 10, y + 20, 4, 8);
    }

    drawZombie(zombie) {
      const x = zombie.x;
      const y = zombie.y;
      const offset = zombie.frame * 2;
      
      this.ctx.fillStyle = '#7CFC00';
      this.ctx.fillRect(x + 10, y + 6, 12, 10);
      
      this.ctx.fillStyle = '#FF0000';
      this.ctx.fillRect(x + 12, y + 8, 2, 2);
      this.ctx.fillRect(x + 18, y + 8, 2, 2);
      
      this.ctx.fillStyle = '#228B22';
      this.ctx.fillRect(x + 8, y + 16, 16, 14);
      
      this.ctx.fillStyle = '#8B0000';
      this.ctx.fillRect(x + 10, y + 20, 4, 4);
      this.ctx.fillRect(x + 18, y + 22, 3, 3);
      
      this.ctx.fillStyle = '#556B2F';
      this.ctx.fillRect(x + 8, y + 30 + offset, 8, 18 - offset);
      this.ctx.fillRect(x + 16, y + 30 - offset, 8, 18 + offset);
    }

    drawFatZombie(zombie) {
      const x = zombie.x;
      const y = zombie.y;
      const offset = zombie.frame * 2;
      
      this.ctx.fillStyle = '#7CFC00';
      this.ctx.fillRect(x + 8, y + 4, 20, 14);
      
      this.ctx.fillStyle = '#FF0000';
      this.ctx.fillRect(x + 12, y + 8, 3, 3);
      this.ctx.fillRect(x + 21, y + 8, 3, 3);
      
      this.ctx.fillStyle = '#228B22';
      this.ctx.fillRect(x + 4, y + 18, 28, 20);
      
      this.ctx.fillStyle = '#8B0000';
      this.ctx.fillRect(x + 8, y + 22, 6, 6);
      this.ctx.fillRect(x + 20, y + 24, 5, 5);
      this.ctx.fillRect(x + 12, y + 30, 8, 4);
      
      this.ctx.fillStyle = '#556B2F';
      this.ctx.fillRect(x + 6, y + 38 + offset, 10, 18 - offset);
      this.ctx.fillRect(x + 20, y + 38 - offset, 10, 18 + offset);
    }

    shoot() {
      this.bullets.push({
        x: this.player.x + this.player.width,
        y: this.player.y + this.player.height / 2 - 2,
        width: 8,
        height: 4,
        speed: 12
      });
      
      for (let i = 0; i < 10; i++) {
        this.particles.push({
          x: this.player.x + this.player.width,
          y: this.player.y + this.player.height / 2,
          vx: Math.random() * 5 + 2,
          vy: (Math.random() - 0.5) * 5,
          size: 2,
          color: '#ffff00',
          life: 12
        });
      }
    }

    spawnZombie() {
      const isFat = Math.random() < 0.15;
      
      let health;
      if (isFat) {
        health = 5;
      } else {
        const healthRoll = Math.random();
        if (healthRoll < 0.6) {
          health = 1;
        } else if (healthRoll < 0.9) {
          health = 2;
        } else {
          health = 3;
        }
      }
      
      const speedVariation = Math.random() * 0.8 + 0.6;
      const speed = this.baseSpeed * speedVariation;
      
      const width = isFat ? 36 : 32;
      const height = isFat ? 56 : 48;
      
      this.zombies.push({
        x: this.canvas.width,
        y: Math.random() * (this.canvas.height - height),
        width: width,
        height: height,
        speed: speed,
        health: health,
        frame: 0,
        isFat: isFat
      });
    }

    createBloodSplatter(x, y) {
      for (let i = 0; i < 16; i++) {
        this.particles.push({
          x: x,
          y: y,
          vx: (Math.random() - 0.5) * 8,
          vy: (Math.random() - 0.5) * 8,
          size: Math.random() * 4 + 1,
          color: '#8B0000',
          life: 25
        });
      }
    }

    checkCollision(rect1, rect2) {
      return rect1.x < rect2.x + rect2.width &&
             rect1.x + rect1.width > rect2.x &&
             rect1.y < rect2.y + rect2.height &&
             rect1.y + rect1.height > rect2.y;
    }

    loseLife() {
      this.lives--;
      this.updateLives();
      
      if (this.lives <= 0) {
        this.gameOver();
      }
    }

    gameOver() {
      this.gameState = 'gameover';
      
      if (this.score > this.highScore) {
        this.highScore = this.score;
        localStorage.setItem('zombieHighScore{{ ai_gen_id }}', this.highScore);
        this.updateHighScore();
      }
      
      this.overlay.querySelector('.ai-zombie-game-title-{{ ai_gen_id }}').textContent = 'GAME OVER';
      this.overlay.querySelector('.ai-zombie-game-message-{{ ai_gen_id }}').textContent = 'Final Score: ' + this.score;
      this.overlay.querySelector('.ai-zombie-game-button-{{ ai_gen_id }}').textContent = 'RESTART';
      this.overlay.classList.remove('hidden');
    }

    updateScore() {
      this.scoreElement.textContent = this.score;
    }

    updateHighScore() {
      this.highScoreElement.textContent = this.highScore;
    }

    updateLives() {
      this.livesContainer.innerHTML = '';
      for (let i = 0; i < this.lives; i++) {
        const heart = document.createElement('canvas');
        heart.className = 'ai-zombie-game-heart-{{ ai_gen_id }}';
        heart.width = 24;
        heart.height = 24;
        const ctx = heart.getContext('2d');
        
        ctx.fillStyle = '#FF0000';
        ctx.fillRect(4, 8, 6, 6);
        ctx.fillRect(14, 8, 6, 6);
        ctx.fillRect(8, 14, 8, 8);
        ctx.fillRect(4, 14, 4, 4);
        ctx.fillRect(16, 14, 4, 4);
        
        this.livesContainer.appendChild(heart);
      }
    }
  }

  customElements.define('zombie-shooter-{{ ai_gen_id }}', ZombieShooter{{ ai_gen_id }});
})();
</script>

{% schema %}
{
  "name": "Zombie shooter game",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border",
      "default": "#7CFC00"
    },
    {
      "type": "color",
      "id": "ui_background",
      "label": "UI background",
      "default": "#2a2a2a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#7CFC00"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title",
      "default": "#FF0000"
    },
    {
      "type": "color",
      "id": "button_color",
