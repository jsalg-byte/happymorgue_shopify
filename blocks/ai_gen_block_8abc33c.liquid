{% doc %}
  @prompt
    give me a layout to add pictures of my upcoming game make super simple , make it less symmetrical and more abstract, a little less abstract , remove 5 and 6 and make 2 3 and 4 even and a one more to complete it , no you did it wrong. make one big image one the left side and then 4 images on the right being alligned to the big one, MERGE IMAGE 4 AND 5 TO MAKE IT ONE IMAGE, make the images smaller like before
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-game-gallery-{{ ai_gen_id }} {
    padding: 40px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-game-gallery__container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-game-gallery__heading-{{ ai_gen_id }} {
    text-align: center;
    margin: 0 0 30px;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.heading_size }}px;
  }

  .ai-game-gallery__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    grid-template-rows: repeat(2, 200px);
    gap: {{ block.settings.spacing }}px;
  }

  .ai-game-gallery__item-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-game-gallery__item-{{ ai_gen_id }}:nth-child(1) {
    grid-column: 1 / 2;
    grid-row: 1 / 3;
  }

  .ai-game-gallery__item-{{ ai_gen_id }}:nth-child(2) {
    grid-column: 2 / 3;
    grid-row: 1 / 2;
  }

  .ai-game-gallery__item-{{ ai_gen_id }}:nth-child(3) {
    grid-column: 3 / 4;
    grid-row: 1 / 2;
  }

  .ai-game-gallery__item-{{ ai_gen_id }}:nth-child(4) {
    grid-column: 2 / 4;
    grid-row: 2 / 3;
  }

  .ai-game-gallery__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-game-gallery__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-game-gallery__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-game-gallery__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 8px 16px;
    background-color: rgba(0, 0, 0, 0.7);
    color: #ffffff;
    font-size: 12px;
    border-radius: 4px;
    white-space: nowrap;
  }

  .ai-game-gallery__caption-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 12px;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.8), transparent);
    color: #ffffff;
    font-size: 14px;
    text-align: center;
  }

  @media screen and (max-width: 749px) {
    .ai-game-gallery__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
    }

    .ai-game-gallery__item-{{ ai_gen_id }}:nth-child(1),
    .ai-game-gallery__item-{{ ai_gen_id }}:nth-child(2),
    .ai-game-gallery__item-{{ ai_gen_id }}:nth-child(3),
    .ai-game-gallery__item-{{ ai_gen_id }}:nth-child(4) {
      grid-column: 1;
      grid-row: auto;
      aspect-ratio: 16 / 9;
    }

    .ai-game-gallery__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }
  }
{% endstyle %}

<div class="ai-game-gallery-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-game-gallery__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-game-gallery__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ai-game-gallery__grid-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign image_key = 'image_' | append: i
          assign caption_key = 'caption_' | append: i
          assign image = block.settings[image_key]
          assign caption = block.settings[caption_key]
        %}

        <div class="ai-game-gallery__item-{{ ai_gen_id }}">
          {% if image %}
            <img
              src="{{ image | image_url: width: 1200 }}"
              alt="{{ image.alt | escape }}"
              loading="lazy"
              width="{{ image.width }}"
              height="{{ image.height }}"
              class="ai-game-gallery__image-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-game-gallery__placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
              <div class="ai-game-gallery__empty-state-{{ ai_gen_id }}">
                Add image {{ i }}
              </div>
            </div>
          {% endif %}

          {% if caption != blank %}
            <div class="ai-game-gallery__caption-{{ ai_gen_id }}">
              {{ caption }}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

